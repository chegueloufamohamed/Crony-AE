<!-- GTM Deferred Load -->
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}

// Store GTM load for after page interactive
function loadGTM() {
  if (window._gtmLoaded) return;
  window._gtmLoaded = true;

  // Load main GTM
  (function(w,d,s,l,i){
    w[l]=w[l]||[];
    w[l].push({'gtm.start': new Date().getTime(), event:'gtm.js'});
    var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),
        dl=l!='dataLayer'?'&l='+l:'';
    j.async=true;
    j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
    f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MN6KN2NC');
}

// Load GTM after user first interacts — not on initial page load
var _gtmEvents = ['mousedown','mousemove','touchstart','scroll','keydown'];
_gtmEvents.forEach(function(e) {
  window.addEventListener(e, function() { loadGTM(); }, { once: true, passive: true });
});

// Safety fallback — load after 5 seconds no matter what
setTimeout(loadGTM, 5000);
</script>
