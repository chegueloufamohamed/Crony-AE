<script
  type="application/json"
  data-section-type="slideshow"
  data-section-id="{{ section.id }}"
>
</script>

{% liquid
  assign id = section.id
  assign mobile_text_alpha = section.settings.mobile_text_color | default: 'rgba(0,0,0,0)' | color_extract: 'alpha'
  assign object_selector = '#shopify-section-' | append: id
%}

{% style %}
  {% render 'section-space' %}
  {% if section.settings.mobile_text_below_image and mobile_text_alpha != 0 %}
    @media only screen and (max-width: 480px) {
      {{ object_selector }} .pretext,
      {{ object_selector }} .headline,
      {{ object_selector }} .subtitle {
        color: {{ section.settings.mobile_text_color }};
      }
    }
  {% endif %}

  {%
    render 'css-loop',
    css: section.settings.custom_css,
    id: id,
  %}

  /* Perf: avoid layout/paint for offscreen slides */
  {{ object_selector }} .homepage-slideshow .gallery-cell {
    content-visibility: auto;
    contain-intrinsic-size: 800px 450px;
  }

  {{ object_selector }} .homepage-slideshow .caption {
    will-change: transform;
  }

  /* Accessible "skip slideshow" link: hidden visually, visible on focus */
  {{ object_selector }} .crony-skip-carousel {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    z-index: -1;
  }

  {{ object_selector }} .crony-skip-carousel:focus,
  {{ object_selector }} .crony-skip-carousel:active {
    position: static;
    width: auto;
    height: auto;
    padding: 8px 12px;
    margin-bottom: 8px;
    background: #000;
    color: #fff;
    z-index: 9999;
    outline: 2px solid #fff;
    outline-offset: 2px;
    display: inline-block;
  }
{% endstyle %}

{% if section.blocks.size > 0 %}
  <section
    class="
      section
      {% if section.settings.wide_display == true %}
        is-width-wide
        has-no-side-gutter
      {% endif %}
      {{ section.settings.css_class }}
    "
  >
    <div class="container">
      <div class="one-whole column">

        {%- comment -%}
          Skip link: allows keyboard / SR users to bypass slideshow quickly
        {%- endcomment -%}
        <a
          href="#slideshow-after-{{ id }}"
          class="crony-skip-carousel"
        >
          Skip homepage slideshow
        </a>

        <div
          class="
            banner
            homepage-slideshow
            js-homepage-slideshow
            slideshow-transition--{{ section.settings.slideshow_animation }}
            {% if section.settings.slideshow_text_animation != '' %}
              text-animation--true
            {% else %}
              text-animation--false
            {% endif %}
            transparentBackground--{{ settings.slideshow_button_style }}
            full-width--{{ section.settings.wide_display }}
          "
          id="homepage_slider-{{ id }}"
          data-slider-id="homepage_slider-{{ id }}"
          data-slideshow-speed="{{ section.settings.slideshow_speed }}"
          data-slideshow-text-animation="{{ section.settings.slideshow_text_animation }}"
          data-adaptive-height="{{ section.settings.activate_adaptiveHeight }}"
          aria-roledescription="carousel"
          aria-label="Homepage slideshow"
          aria-live="polite"
          role="region"
          tabindex="0"
        >
          {% for block in section.blocks %}
            {%- comment -%}
              Perf profile (Option C):
              • Slide 1: eager + fetchpriority=high  (true LCP)
              • Slide 2: eager + low priority       (smooth first transition)
              • Others: lazy + low priority
            {%- endcomment -%}
            {% if forloop.index == 1 %}
              {% assign img_loading = 'eager' %}
              {% assign img_fetchpriority = 'high' %}
            {% elsif forloop.index == 2 %}
              {% assign img_loading = 'eager' %}
              {% assign img_fetchpriority = 'low' %}
            {% else %}
              {% assign img_loading = 'lazy' %}
              {% assign img_fetchpriority = 'low' %}
            {% endif %}

            <div
              class="
                gallery-cell
                slide-{{ forloop.index }}
                caption-background-{{ block.settings.caption_content_background }}
                caption--below-{{ section.settings.mobile_text_below_image }}
              "
              {{ block.shopify_attributes }}
              data-block-id="{{ block.id }}"
              role="group"
              aria-roledescription="slide"
              aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            >
              {% if block.settings.mobile_image %}
                <div class="is-hidden-mobile-only">
              {% endif %}

              {% if block.settings.image %}
                {% comment %}
                  Desktop image
                {% endcomment %}
                {%
                  render 'image-element',
                  image: block.settings.image,
                  alt: block.settings.image.alt,
                  stretch_width: true,
                  focal_point: block.settings.image.presentation.focal_point,
                  loading: img_loading,
                  fetchpriority: img_fetchpriority,
                  decoding: 'async',
                  sizes: '(max-width: 768px) 100vw, 1800px'
                %}

                {% if block.settings.caption_content_background == 'darken_bg' %}
                  <div class="darken-bg"></div>
                {% endif %}
              {% else %}
                {% capture i %}{% cycle "1", "2" %}{% endcapture %}
                {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg placeholder-svg--slideshow' }}
              {% endif %}

              {% if block.settings.mobile_image %}
                </div>
                <div class="is-hidden-desktop-only">
                  {% comment %}
                    Mobile-specific image – same loading profile as desktop.
                  {% endcomment %}
                  {%
                    render 'image-element',
                    image: block.settings.mobile_image,
                    alt: block.settings.mobile_image.alt,
                    stretch_width: true,
                    focal_point: block.settings.mobile_image.presentation.focal_point,
                    loading: img_loading,
                    fetchpriority: img_fetchpriority,
                    decoding: 'async',
                    sizes: '100vw'
                  %}

                  {% if block.settings.caption_content_background == 'darken_bg' %}
                    <div class="darken-bg"></div>
                  {% endif %}
                </div>
              {% endif %}

              {%- comment -%}
                Full-slide clickable area:
                Make sure the link has a discernible name.
              {%- endcomment -%}
              {% assign slide_label = block.settings.title | strip | default: 'View slide' %}

              {% unless block.settings.button1_link != blank and block.settings.button2_link != blank %}
                {% if block.settings.button1_link != blank and block.settings.button1 == blank %}
                  <a class="banner-full-link" href="{{ block.settings.button1_link }}">
                    {{ slide_label }}
                  </a>
                {% elsif block.settings.button2_link != blank and block.settings.button2 == blank %}
                  <a class="banner-full-link" href="{{ block.settings.button2_link }}">
                    {{ slide_label }}
                  </a>
                {% endif %}
              {% endunless %}

              {% unless block.settings.pretext == blank and block.settings.title == blank and block.settings.subtitle == blank and block.settings.button1 == blank and block.settings.button2 == blank %}
                <div
                  class="
                    caption
                    position-{{ block.settings.text_position }}
                    js-caption
                  "
                >
                  <div class="caption-content align-{{ block.settings.text_align }}">
                    {% if block.settings.pretext != blank %}
                      <div class="pretext">
                        {{ block.settings.pretext }}
                      </div>
                    {% endif %}

                    {% if forloop.first == true and block.settings.title != blank %}
                      <h1 class="headline">
                        {{ block.settings.title }}
                      </h1>
                    {% elsif block.settings.title != blank %}
                      <p class="headline">
                        {{ block.settings.title }}
                      </p>
                    {% endif %}

                    {% if block.settings.subtitle != blank %}
                      <div class="subtitle">
                        {{ block.settings.subtitle }}
                      </div>
                    {% endif %}

                    {%
                      render 'banner-buttons',
                      button1_text: block.settings.button1,
                      button1_style: block.settings.button1_style,
                      button1_link: block.settings.button1_link,
                      button2_text: block.settings.button2,
                      button2_style: block.settings.button2_style,
                      button2_link: block.settings.button2_link,
                      mobile_text_below_image: section.settings.mobile_text_below_image,
                      mobile_text_color: section.settings.mobile_text_color,
                      object_selector: object_selector,
                    %}
                  </div>
                </div>
              {% endunless %}
            </div>
          {% endfor %}
        </div>

        {%- comment -%}
          Target for "Skip slideshow" link
        {%- endcomment -%}
        <div id="slideshow-after-{{ id }}"></div>

      </div>
    </div>
  </section>
{% endif %}

{%- comment -%}
  Perf + A11y controller for this section:
  • Respects prefers-reduced-motion by disabling autoplay.
  • Uses IntersectionObserver to pause when offscreen.
  • Adds keyboard control (arrows / space / enter).
  • Keeps aria-hidden in sync and strips invalid aria-selected.
{%- endcomment -%}
<script>
(function(){
  var slider = document.getElementById('homepage_slider-{{ id }}');
  if (!slider) return;

  function getFlickity(){
    if (slider.flickity && typeof slider.flickity.playPlayer === 'function') {
      return slider.flickity;
    }
    if (window.jQuery) {
      var $ = window.jQuery;
      var inst = $(slider).data('flickity') || $(slider).data('flickity-instance');
      if (inst && typeof inst.playPlayer === 'function') {
        return inst;
      }
    }
    return null;
  }

  // Ensure gallery cells don't carry bad aria-selected
  function updateSlidesAria() {
    var cells = slider.querySelectorAll('.gallery-cell');
    cells.forEach(function(cell) {
      var isSelected = cell.classList.contains('is-selected');
      cell.setAttribute('aria-hidden', isSelected ? 'false' : 'true');
      cell.removeAttribute('aria-selected');
    });

    // Also clean any custom crony-slide articles / testimonial blocks
    var stray = document.querySelectorAll('.crony-slide[aria-selected], .testimonial-block[aria-selected]');
    stray.forEach(function(node){
      node.removeAttribute('aria-selected');
    });
  }

  function wireFlickityA11y(flkty) {
    if (!flkty || flkty.__cronyA11yWired) return;
    flkty.__cronyA11yWired = true;

    updateSlidesAria();

    if (typeof flkty.on === 'function') {
      flkty.on('select', updateSlidesAria);
      flkty.on('settle', updateSlidesAria);
    }
  }

  // Disable autoplay for users who prefer reduced motion
  try {
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      slider.setAttribute('data-slideshow-speed', '0');
    }
  } catch(e) {}

  // Keyboard navigation
  slider.addEventListener('keydown', function(e) {
    var key = e.key || e.which;
    var flk = getFlickity();
    if (!flk) return;

    if (key === 'ArrowLeft' || key === 37) {
      e.preventDefault();
      if (typeof flk.previous === 'function') flk.previous();
    } else if (key === 'ArrowRight' || key === 39) {
      e.preventDefault();
      if (typeof flk.next === 'function') flk.next();
    } else if (key === ' ' || key === 'Spacebar' || key === 32 || key === 'Enter' || key === 13) {
      e.preventDefault();
      if (typeof flk.next === 'function') flk.next();
    }
  });

  // Pause when offscreen, resume when visible
  if ('IntersectionObserver' in window) {
    var onceBound = false;
    var io = new IntersectionObserver(function(entries){
      var entry = entries[0];
      var flk = getFlickity();
      if (!flk) return;

      if (!onceBound) {
        wireFlickityA11y(flk);
        onceBound = true;
      }

      if (entry.isIntersecting) {
        try { flk.playPlayer && flk.playPlayer(); } catch(e){}
      } else {
        try { flk.pausePlayer && flk.pausePlayer(); } catch(e){}
      }
    }, { root: null, threshold: 0.1 });

    io.observe(slider);
  } else {
    // Fallback: try wiring A11y after a delay if IO not available
    setTimeout(function() {
      var flk = getFlickity();
      wireFlickityA11y(flk);
    }, 1000);
  }

})();
</script>

{% schema %}
{
  "name": "Slideshow",
  "class": "shopify-section--slideshow under-menu",
  "settings": [
    {
      "type": "checkbox",
      "id": "wide_display",
      "label": "Wide display",
      "default": true
    },
    {
      "type": "select",
      "id": "slideshow_text_animation",
      "label": "Text animation",
      "default": "fadeInDown",
      "options": [
        { "value": "fadeIn", "label": "Fade in" },
        { "value": "fadeInUp", "label": "Fade up" },
        { "value": "fadeInDown", "label": "Fade down" },
        { "value": "", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "slideshow_animation",
      "label": "Transition",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" }
      ]
    },
    {
      "type": "range",
      "id": "slideshow_speed",
      "label": "Change slides every",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 6,
      "unit": "sec",
      "info": "Set to 0 to disable autoplay."
    },
    {
      "type": "checkbox",
      "id": "activate_adaptiveHeight",
      "label": "Enable adaptive height",
      "info": "Slideshow will adjust based on height of individual slides",
      "default": false
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "mobile_text_below_image",
      "label": "Show text below image",
      "default": true
    },
    {
      "type": "color",
      "id": "mobile_text_color",
      "label": "Text below image",
      "info": "Set this to 'None' to use the 'Regular text' color."
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "paragraph",
      "content": "[Learn more](https://help.outofthesandbox.com/hc/en-us/articles/360022329373)"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS Class"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image", "info": "1800 x 1000px recommended" },
        { "type": "richtext", "id": "pretext", "label": "Preheading" },
        { "type": "text", "id": "title", "label": "Heading", "default": "Your headline" },
        { "type": "richtext", "id": "subtitle", "label": "Subheading" },
        { "type": "text", "id": "button1", "label": "First button label" },
        { "type": "url", "id": "button1_link", "label": "First slide link" },
        {
          "type": "select",
          "id": "button1_style",
          "label": "First button color",
          "options": [
            { "value": "global-button--primary", "label": "Primary button" },
            { "value": "global-button--banner", "label": "Banner button (outline)" },
            { "value": "global-button--banner-highlighted", "label": "Banner button (solid)" },
            { "value": "global-button--banner-text", "label": "Banner text button (outline)" },
            { "value": "global-button--banner-text-highlighted", "label": "Banner text button (solid)" }
          ],
          "default": "global-button--banner"
        },
        { "type": "text", "id": "button2", "label": "Second button label" },
        { "type": "url", "id": "button2_link", "label": "Second slide link" },
        {
          "type": "select",
          "id": "button2_style",
          "label": "Second button color",
          "options": [
            { "value": "global-button--primary", "label": "Primary button" },
            { "value": "global-button--banner", "label": "Banner button (outline)" },
            { "value": "global-button--banner-highlighted", "label": "Banner button (solid)" },
            { "value": "global-button--banner-text", "label": "Banner text button (outline)" },
            { "value": "global-button--banner-text-highlighted", "label": "Banner text button (solid)" }
          ],
          "default": "global-button--banner"
        },
        { "type": "header", "content": "Content layout" },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text position",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        { "type": "text_alignment", "id": "text_align", "label": "Text alignment", "default": "center" },
        { "type": "header", "content": "Text contrast", "info": "Improve legibility by applying a contrast technique to your banner's text." },
        {
          "type": "select",
          "id": "caption_content_background",
          "label": "Contrast technique",
          "default": "original",
          "options": [
            { "value": "original", "label": "None" },
            { "value": "darken_bg", "label": "Darken banner image" },
            { "value": "text_box", "label": "Solid box" },
            { "value": "translucent_text_box", "label": "Translucent box" }
          ]
        },
        { "type": "header", "content": "Mobile" },
        { "type": "image_picker", "id": "mobile_image", "label": "Image", "info": "Display a different image on mobile screens. This only appears when the desktop image is set." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "category": "Image",
      "settings": {},
      "blocks": [
        { "type": "image", "settings": { "title": "Turbo Shopify Theme", "text_align": "center" } },
        { "type": "image", "settings": { "text_align": "center" } }
      ]
    }
  ],
  "disabled_on": { "groups": [ "*" ] }
}
{% endschema %}
