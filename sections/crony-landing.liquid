<!-- BILINGUAL & INTERACTIVE SCRIPTS -->
<script>
  // Language switcher logic
  function toggleLanguage() {
    var wrapper = document.getElementById('crony-landing-section');
    var switcherBtn = document.querySelector('.crony-top-lang-switcher');
    
    if (wrapper.classList.contains('crony-lang-en')) {
      // Switch to Arabic
      wrapper.classList.remove('crony-lang-en');
      wrapper.classList.add('crony-lang-ar');
      document.body.dir = "rtl"; // Mirror the whole page layout natively
      localStorage.setItem('crony_landing_language', 'ar');
    } else {
      // Switch to English
      wrapper.classList.remove('crony-lang-ar');
      wrapper.classList.add('crony-lang-en');
      document.body.dir = "ltr"; // Default page layout direction
      localStorage.setItem('crony_landing_language', 'en');
    }
  }

  // Load language preference from local storage if exists
  function loadLanguagePreference() {
    var savedLang = localStorage.getItem('crony_landing_language');
    if (savedLang === 'ar') {
      var wrapper = document.getElementById('crony-landing-section');
      if (wrapper) {
        wrapper.classList.remove('crony-lang-en');
        wrapper.classList.add('crony-lang-ar');
        document.body.dir = "rtl";
      }
    }
  }

  // Countdown timer logic
  function initCountdown() {
    var timerKey = 'crony_timer_deadline';
    var deadline = localStorage.getItem(timerKey);
    
    if (!deadline) {
      var durationMs = (23 * 60 * 60 + 45 * 60) * 1000;
      deadline = new Date().getTime() + durationMs;
      localStorage.setItem(timerKey, deadline);
    } else {
      deadline = parseInt(deadline, 10);
      if (new Date().getTime() > deadline) {
        var durationMs = (23 * 60 * 60 + 45 * 60) * 1000;
        deadline = new Date().getTime() + durationMs;
        localStorage.setItem(timerKey, deadline);
      }
    }

    function updateTimer() {
      var now = new Date().getTime();
      var distance = deadline - now;

      if (distance < 0) {
        clearInterval(timerInterval);
        document.getElementById('crony-timer').innerHTML = "<span class='num'>EXPIRED / منتهي</span>";
        return;
      }

      var days = Math.floor(distance / (1000 * 60 * 60 * 24));
      var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      var seconds = Math.floor((distance % (1000 * 60)) / 1000);

      document.getElementById('timer-days').innerText = String(days).padStart(2, '0');
      document.getElementById('timer-hours').innerText = String(hours).padStart(2, '0');
      document.getElementById('timer-mins').innerText = String(minutes).padStart(2, '0');
      document.getElementById('timer-secs').innerText = String(seconds).padStart(2, '0');
    }

    updateTimer();
    var timerInterval = setInterval(updateTimer, 1000);
  }

  // Image Gallery switcher
  function switchGalleryImage(element, imageUrl) {
    document.getElementById('main-product-img').src = imageUrl;
    var thumbs = document.querySelectorAll('.thumb-item');
    thumbs.forEach(function(item) {
      item.classList.remove('active');
    });
    element.classList.add('active');
  }

  // Tab panel switcher
  function switchTab(evt, tabId) {
    var tabContents = document.querySelectorAll('.tab-content');
    tabContents.forEach(function(content) {
      content.classList.remove('active');
    });

    var tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(function(btn) {
      btn.classList.remove('active');
    });

    document.getElementById(tabId).classList.add('active');
    evt.currentTarget.classList.add('active');
  }



  // FAQ accordion toggler
  function toggleFaq(element) {
    var parent = element.parentElement;
    parent.classList.toggle('active');
  }


  // Mobile Sticky bottom bar scroll trigger
  function initStickyBar() {
    var stickyBar = document.getElementById('crony-sticky-bar');
    var mainForm = document.querySelector('.product-buy-form');
    
    if (!stickyBar || !mainForm) return;

    window.addEventListener('scroll', function() {
      var rect = mainForm.getBoundingClientRect();
      if (rect.bottom < 0) {
        stickyBar.classList.add('slide-up');
      } else {
        stickyBar.classList.remove('slide-up');
      }
    });
  }

  // Smooth scroll for nav anchor links
  function initAnchorScrolling() {
    document.querySelectorAll('.crony-nav-menu a, .crony-logo-link').forEach(function(anchor) {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        var targetId = this.getAttribute('href');
        var targetSection = document.querySelector(targetId);
        
        if (targetSection) {
          targetSection.scrollIntoView({
            behavior: 'smooth'
          });
        }
      });
    });
  }

  // Bind initializers on DOM load
  document.addEventListener('DOMContentLoaded', function() {
    loadLanguagePreference();
    initCountdown();
    initStickyBar();
    initAnchorScrolling();
  });
</script>

