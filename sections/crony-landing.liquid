{% comment %}
  CRONY.AE - Bilingual (EN/AR) White-themed Premium Landing Page
  Created by Antigravity
  Restricted to this self-contained file to keep your theme 100% safe.
{% endcomment %}

{% assign main_product = all_products[section.settings.target_product] %}

{% comment %} Fallback data for preview/fallback mode {% endcomment %}
{% assign fallback_title_en = "CRONY V10 Smart Electric Scooter" %}
{% assign fallback_title_ar = "سكوتر كروني V10 الكهربائي الذكي" %}
{% assign fallback_price = 118000 %}
{% assign fallback_compare_price = 130000 %}

{% if main_product != blank %}
  {% assign product_title = main_product.title %}
  {% assign product_price = main_product.price %}
  {% assign product_compare_price = main_product.compare_at_price %}
  {% assign product_variant_id = main_product.first_available_variant.id %}
{% else %}
  {% assign product_title = fallback_title_en %}
  {% assign product_price = fallback_price %}
  {% assign product_compare_price = fallback_compare_price %}
  {% assign product_variant_id = "1234567890" %}
{% endif %}


  <!-- 02 PRODUCT HERO SECTION -->
  <section id="crony-product-hero" class="crony-hero-section section-padding scroll-margin">
    <div class="crony-container grid-two-col">
      
      <!-- Left: Gallery Column -->
      <div class="gallery-column">
        <div class="main-image-container">
          <span class="badge-sale">
            <span class="txt-en">10% OFF</span><span class="txt-ar">خصم 10%</span>
          </span>
          {% if main_product != blank and main_product.featured_image != blank %}
            <img id="main-product-img" src="{{ main_product.featured_image | img_url: '800x800' }}" alt="{{ product_title }}" width="800" height="800" class="main-img">
          {% else %}
            <img id="main-product-img" src="{{ 'crony-v10-scooter.png' | asset_url }}" alt="{{ fallback_title_en }}" width="800" height="800" class="main-img">
          {% endif %}
        </div>
        <div class="thumbnail-list">
          {% if main_product != blank %}
            {% for image in main_product.images limit: 5 %}
              <div class="thumb-item {% if forloop.first %}active{% endif %}" onclick="switchGalleryImage(this, '{{ image | img_url: '800x800' }}')">
                <img src="{{ image | img_url: '150x150' }}" alt="Thumbnail" width="150" height="150">
              </div>
            {% endfor %}
          {% else %}
            <div class="thumb-item active" onclick="switchGalleryImage(this, '{{ 'crony-v10-scooter.png' | asset_url }}')">
              <img src="{{ 'crony-v10-scooter.png' | asset_url }}" alt="Thumbnail 1" width="150" height="150">
            </div>
            <div class="thumb-item" onclick="switchGalleryImage(this, 'https://cdn.shopify.com/s/files/1/0662/3621/9628/files/New_Project_2.webp')">
              <img src="https://cdn.shopify.com/s/files/1/0662/3621/9628/files/New_Project_2.webp" alt="Thumbnail 2" width="150" height="150">
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Right: Details Column -->
      <div class="details-column">
        <div class="rating-stars">
          <span class="stars">★★★★★</span>
          <span class="reviews-count">
            <span class="txt-en">4.9/5 (184 Verified Reviews)</span>
            <span class="txt-ar">4.9/5 (184 تقييم عملاء موثق)</span>
          </span>
        </div>

        <h1 class="product-title">
          {% if main_product != blank %}
            {{ product_title }}
          {% else %}
            <span class="txt-en">{{ fallback_title_en }}</span>
            <span class="txt-ar">{{ fallback_title_ar }}</span>
          {% endif %}
        </h1>
        <p class="tagline">
          <span class="txt-en">Premium Electric Commuter Scooter - Speed, Power & Ultimate Safety</span>
          <span class="txt-ar">أقوى سكوتر كهربائي للتنقل اليومي - سرعة، قوة، وأمان متكامل</span>
        </p>

        <!-- Price Container -->
        <div class="price-container">
          <span class="current-price">{{ product_price | money }}</span>
          <span class="compare-price">{{ product_compare_price | money }}</span>
          <span class="save-tag">
            <span class="txt-en">Save {{ product_compare_price | minus: product_price | money }}!</span>
            <span class="txt-ar">وفر {{ product_compare_price | minus: product_price | money }}!</span>
          </span>
        </div>

        <!-- Inventory Urgency -->
        <div class="inventory-bar">
          <div class="inv-head">
            <span class="inv-title">
              <span class="txt-en">⚠️ HURRY! LIMITED STOCK</span>
              <span class="txt-ar">⚠️ عاجل: الكمية محدودة جداً</span>
            </span>
            <span class="inv-count">
              <span class="txt-en">Only 3 units left at this price!</span>
              <span class="txt-ar">متبقي 3 قطع فقط بهذا السعر!</span>
            </span>
          </div>
          <div class="inv-progress">
            <div class="inv-progress-fill" style="width: 15%;"></div>
          </div>
        </div>

        <div class="product-highlights">
          <ul>
            <li>
              <span class="txt-en">🚚 <strong>Free & Fast Shipping</strong> across all UAE (24-48 Hours)</span>
              <span class="txt-ar">🚚 <strong>شحن مجاني وسريع</strong> لجميع مدن الإمارات (24-48 ساعة)</span>
            </li>
            <li>
              <span class="txt-en">🤝 <strong>Cash on Delivery (COD)</strong> available at your doorstep</span>
              <span class="txt-ar">🤝 <strong>الدفع عند الاستلام (COD)</strong> متوفر عند باب بيتك</span>
            </li>
            <li>
              <span class="txt-en">🛡️ <strong>1-Year Golden Warranty</strong> on motor & battery</span>
              <span class="txt-ar">🛡️ <strong>ضمان ذهبي لمدة عام</strong> كامل على المحرك والبطارية</span>
            </li>
          </ul>
        </div>

        <!-- Purchase Action Form -->
        {% if main_product != blank %}
          {% form 'product', main_product, class: 'product-buy-form' %}
            <input type="hidden" name="id" value="{{ product_variant_id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn-primary btn-pulse" name="add">
              <span class="txt-en">BUY NOW & SAVE 10%</span>
              <span class="txt-ar">اشترِ الآن ووفر 10%</span>
              <small>
                <span class="txt-en">Cash on Delivery Available</span>
                <span class="txt-ar">الدفع عند الاستلام متاح</span>
              </small>
            </button>
          {% endform %}
        {% else %}
          <div class="product-buy-form">
            <a href="https://uaecrony.myshopify.com/cart/{{ product_variant_id }}:1" class="btn-primary btn-pulse" id="mock-checkout-btn">
              <span class="txt-en">BUY NOW & SAVE 10%</span>
              <span class="txt-ar">اشترِ الآن ووفر 10%</span>
              <small>
                <span class="txt-en">Cash on Delivery Available</span>
                <span class="txt-ar">الدفع عند الاستلام متاح</span>
              </small>
            </a>
          </div>
        {% endif %}

        <!-- Trust Icons -->
        <div class="trust-icons-grid">
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M18 18.5a1.5 1.5 0 0 1-3 0 1.5 1.5 0 0 1 3 0m-9 0a1.5 1.5 0 0 1-3 0 1.5 1.5 0 0 1 3 0M20 8l-3-4H4a2 2 0 0 0-2 2v10h2a3 3 0 0 0 6 0h4a3 3 0 0 0 6 0h2v-5l-3-3m-3-2.5l2.1 2.8H15V5.5M4 6h9v5H4V6m17 7h-2v-2h2v2z"/></svg>
            <span>
              <span class="txt-en">Free Fast Delivery</span>
              <span class="txt-ar">توصيل مجاني وسريع</span>
            </span>
          </div>
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10s10-4.5 10-10S17.5 2 12 2m0 4a3 3 0 0 1 3 3a3 3 0 0 1-3 3a3 3 0 0 1-3-3a3 3 0 0 1 3-3m0 14.2c-2.5 0-4.7-1.3-6-3.2c0-2 4-3.1 6-3.1s6 1.1 6 3.1c-1.3 1.9-3.5 3.2-6 3.2z"/></svg>
            <span>
              <span class="txt-en">Cash on Delivery</span>
              <span class="txt-ar">الدفع عند الاستلام</span>
            </span>
          </div>
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 22s8-4 8-10V5l-8-3l-8 3v7c0 6 8 10 8 10m0-18.1l6.1 2.3v5.8c0 4.5-5.3 7.9-6.1 8.5c-.8-.6-6.1-4-6.1-8.5V6.2L12 3.9z"/></svg>
            <span>
              <span class="txt-en">1-Year Warranty</span>
              <span class="txt-ar">ضمان لمدة عام</span>
            </span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 03 DESCRIPTION & FEATURES -->
  <section id="crony-features" class="crony-desc-section section-padding scroll-margin alt-bg">
    <div class="crony-container">
      
      <div class="section-title-wrap">
        <h2 class="section-title">
          <span class="txt-en">Why Choose the CRONY V10?</span>
          <span class="txt-ar">لماذا تختار سكوتر كروني V10؟</span>
        </h2>
        <p class="section-subtitle">
          <span class="txt-en">The ultimate solution to bypass daily traffic jams - save time and money!</span>
          <span class="txt-ar">الحل الأمثل لتفادي زحام الطرقات يومياً - وفر وقتك ومالك!</span>
        </p>
      </div>

      <!-- Grid features -->
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>
            <span class="txt-en">1200W Powerful Motor</span>
            <span class="txt-ar">محرك قوي بقوة 1200 واط</span>
          </h3>
          <p>
            <span class="txt-en">Unmatched acceleration to tackle urban slopes and bridges up to 20° easily.</span>
            <span class="txt-ar">تسارع قوي وسلس يساعدك على تخطي المرتفعات والجسور بزاوية صعود تصل إلى 20 درجة بكل سهولة.</span>
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔋</div>
          <h3>
            <span class="txt-en">48V/14AH Long Range Battery</span>
            <span class="txt-ar">بطارية طويلة المدى 48V/14AH</span>
          </h3>
          <p>
            <span class="txt-en">Commute freely with up to 35 km range per charge. Built-in BMS protection.</span>
            <span class="txt-ar">تمنحك مسافة قيادة تصل إلى 35 كم في الشحنة الواحدة لتغطية تنقلاتك اليومية دون القلق من نفاد الشحن.</span>
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🚲</div>
          <h3>
            <span class="txt-en">Dual Suspension Comfort</span>
            <span class="txt-ar">نظام تعليق مزدوج مريح</span>
          </h3>
          <p>
            <span class="txt-en">Front and rear spring shock absorbers ensure a smooth ride even on bumpy roads.</span>
            <span class="txt-ar">مساعدين أماميين وخلفيين لامتصاص الصدمات والاهتزازات، لتستمتع بقيادة مريحة جداً حتى على الطرق غير الممهدة.</span>
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🛑</div>
          <h3>
            <span class="txt-en">Dual Disc Braking System</span>
            <span class="txt-ar">مكابح قرصية مزدوجة آمنة</span>
          </h3>
          <p>
            <span class="txt-en">Dual front and rear disc brakes with E-ABS prevent lock-ups for instant safe stopping.</span>
            <span class="txt-ar">نظام مكابح قرصية أمامي وخلفي مزدوج، مع E-ABS لمنع الانغلاق، يضمن لك مسافة توقف فائقة القصر والآمن.</span>
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚙️</div>
          <h3>
            <span class="txt-en">Quick Folding in 3 Seconds</span>
            <span class="txt-ar">تصميم قابل للطي السريع</span>
          </h3>
          <p>
            <span class="txt-en">Easy folding mechanism locks the stem. Light enough to carry onto metro or store in trunks.</span>
            <span class="txt-ar">تثبيت ذكي يسمح لك بطي السكوتر في 3 ثوانٍ فقط لحمله بيدك، وضعه في صندوق السيارة، أو ركوب المترو.</span>
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📱</div>
          <h3>
            <span class="txt-en">Smart LCD Display</span>
            <span class="txt-ar">شاشة عرض رقمية ذكية</span>
          </h3>
          <p>
            <span class="txt-en">Tracks speed, battery status, and gear mode. Highly visible even under bright sunlight.</span>
            <span class="txt-ar">شاشة LCD كبيرة تعرض السرعة الحالية، وضع القيادة، ومستوى البطارية بوضوح تام حتى تحت أشعة الشمس المباشرة.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 04 TECHNICAL SPECS & WARRANTY -->
  <section id="crony-specs" class="crony-specs-section section-padding scroll-margin">
    <div class="crony-container">
      
      <div class="section-title-wrap">
        <h2 class="section-title">
          <span class="txt-en">Specifications & Warranty</span>
          <span class="txt-ar">المواصفات الفنية والضمان</span>
        </h2>
      </div>

      <!-- Tab Layout -->
      <div class="crony-tabs-wrapper">
        <div class="tab-buttons">
          <button class="tab-btn active" onclick="switchTab(event, 'tab-details')">
            <span class="txt-en">Description</span><span class="txt-ar">الوصف والمميزات</span>
          </button>
          <button class="tab-btn" onclick="switchTab(event, 'tab-tech')">
            <span class="txt-en">Technical Specs</span><span class="txt-ar">المواصفات التقنية</span>
          </button>
          <button class="tab-btn" onclick="switchTab(event, 'tab-warranty-details')">
            <span class="txt-en">Warranty & Support</span><span class="txt-ar">الضمان والدعم</span>
          </button>
        </div>

        <!-- Tab: Details -->
        <div id="tab-details" class="tab-content active">
          <p>
            <span class="txt-en">The CRONY V10 Commuter Scooter is engineered specifically for city riders in the UAE. Crafted from high-strength aviation-grade aluminum, it offers durability without unnecessary weight. Equipped with a high-intensity front LED headlight, side atmospheric safety running lights, and active brake lights, it ensures maximum visibility and safety for night riding.</span>
            <span class="txt-ar">صُمم سكوتر كروني V10 الكهربائي ليلبي احتياجات التنقل السريع والذكي في دولة الإمارات. يتمتع بهيكل خارجي متين مصنوع من الألمنيوم المخصص لصناعة الطائرات، مما يضمن خفة الوزن مع صلابة قصوى. ويتميز بإضاءات ليلية ممتازة تشمل كشاف LED أمامي ساطع، وإضاءة خلفية للفرامل، بالإضافة إلى شريط إضاءة جانبي لضمان رؤيتك بوضوح وتوفير أقصى درجات الأمان.</span>
          </p>
        </div>

        <!-- Tab: Specs -->
        <div id="tab-tech" class="tab-content">
          <table class="specs-table">
            <tr>
              <td><strong><span class="txt-en">Max Speed</span><span class="txt-ar">السرعة القصوى</span></strong></td>
              <td><span class="txt-en">Up to 45 km/h</span><span class="txt-ar">تصل إلى 45 كم/ساعة</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Battery Range</span><span class="txt-ar">المسافة المقطوعة</span></strong></td>
              <td><span class="txt-en">25 - 35 km (varies by weight & terrain)</span><span class="txt-ar">من 25 إلى 35 كم (حسب الوزن والسرعة)</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Motor Peak Power</span><span class="txt-ar">قوة المحرك</span></strong></td>
              <td><span class="txt-en">1200 Watts</span><span class="txt-ar">1200 واط (Peak Power)</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Battery Capacity</span><span class="txt-ar">سعة البطارية</span></strong></td>
              <td><span class="txt-en">Lithium-ion 48V / 14AH</span><span class="txt-ar">ليثيوم أيون 48V / 14AH</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Full Charging Time</span><span class="txt-ar">زمن الشحن الكامل</span></strong></td>
              <td><span class="txt-en">5 - 7 Hours</span><span class="txt-ar">من 5 إلى 7 ساعات</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Max Loading Capacity</span><span class="txt-ar">أقصى وزن للمستخدم</span></strong></td>
              <td><span class="txt-en">120 kg</span><span class="txt-ar">120 كجم</span></td>
            </tr>
            <tr>
              <td><strong><span class="txt-en">Scooter Net Weight</span><span class="txt-ar">الوزن الصافي للسكوتر</span></strong></td>
              <td><span class="txt-en">18.5 kg</span><span class="txt-ar">18.5 كجم</span></td>
            </tr>
          </table>
        </div>

        <!-- Tab: Warranty -->
        <div id="tab-warranty-details" class="tab-content">
          <div class="warranty-card">
            <h3>
              <span class="txt-en">🛡️ Golden Warranty & Returns Policy</span>
              <span class="txt-ar">🛡️ الضمان الذهبي وسياسة الاسترجاع</span>
            </h3>
            <p>
              <span class="txt-en">We stand behind our build quality. We provide:</span>
              <span class="txt-ar">نحن نلتزم بتقديم أفضل جودة لعملائنا، لذلك نوفر لك:</span>
            </p>
            <ul>
              <li>
                <span class="txt-en"><strong>1-Year Warranty:</strong> Covers motor, battery, and electronic controllers against manufacturing defects.</span>
                <span class="txt-ar"><strong>ضمان شامل لمدة عام:</strong> يغطي هذا الضمان المحرك الكهربائي، والبطارية، ولوحة التحكم ضد أي عيوب تصنيعية.</span>
              </li>
              <li>
                <span class="txt-en"><strong>7-Day Replacement Policy:</strong> Direct replacement if any factory defects are found upon delivery.</span>
                <span class="txt-ar"><strong>سياسة استبدال مرنة:</strong> يمكنك استبدال المنتج خلال 7 أيام في حال وجود أي عيب مصنعي عند الاستلام.</span>
              </li>
              <li>
                <span class="txt-en"><strong>Local Spare Parts Support:</strong> Full warehouse of parts and professional technicians based in Dubai.</span>
                <span class="txt-ar"><strong>دعم فني وصيانة متخصصة:</strong> نوفر جميع قطع الغيار الأصلية في دبي ولدينا فريق صيانة محترف لخدمتك.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- 05 VIDEO SHOWCASE -->
  <section id="crony-video" class="crony-video-section section-padding scroll-margin alt-bg">
    <div class="crony-container">
      <div class="section-title-wrap">
        <h2 class="section-title">
