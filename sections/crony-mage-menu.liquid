{% comment %}
  Mega Menu Section - Flexible Two-Level Menu
  File: sections/mega-menu.liquid
{% endcomment %}

<div class="mega-menu-wrapper">
  {%- comment -%} Top Bar: Social Icons on Left, Cart on Right {%- endcomment -%}
  <div class="mega-menu-top-bar">
    <div class="mega-menu-top-container">
      {%- comment -%} Left: Social Media Icons {%- endcomment -%}
      <div class="top-bar-left">
        {% if section.settings.facebook_url != blank %}
          <a href="{{ section.settings.facebook_url }}" target="_blank" class="social-icon" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" target="_blank" class="social-icon" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.twitter_url != blank %}
          <a href="{{ section.settings.twitter_url }}" target="_blank" class="social-icon" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.youtube_url != blank %}
          <a href="{{ section.settings.youtube_url }}" target="_blank" class="social-icon" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" target="_blank" class="social-icon" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
            </svg>
          </a>
        {% endif %}
      </div>

      {%- comment -%} Right: Cart Icon {%- endcomment -%}
      <div class="top-bar-right">
        <a href="{{ routes.cart_url }}" class="top-cart-link">
          {% if section.settings.cart_icon != blank %}
            {{ section.settings.cart_icon | image_url: width: 24 | image_tag: alt: 'Cart', class: 'cart-icon-image' }}
          {% else %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 2L7 6M17 2l2 4M3 6h18M5 6l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
          <span class="top-cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>


  <div class="mega-menu-container">
    
    {%- comment -%} Column 1: Logo {%- endcomment -%}
<div class="mega-menu-logo">
  {% if section.settings.logo != blank %}
    <a href="{{ routes.root_url }}" class="logo-link">
      <img 
        src="{{ section.settings.logo | image_url: width: 260 }}" 
        srcset="{{ section.settings.logo | image_url: width: 260 }} 1x,
                {{ section.settings.logo | image_url: width: 520 }} 2x"
        alt="{{ shop.name }}" 
        width="130" 
        height="28"
        loading="eager"
        class="logo-image">
    </a>
  {% else %}
    <a href="{{ routes.root_url }}" class="logo-link logo-text">
      {{ shop.name }}
    </a>
  {% endif %}
</div>

    {%- comment -%} Column 2: Menu Items {%- endcomment -%}
    <nav class="mega-menu-nav">
      <ul class="menu-list">
        {% for block in section.blocks %}
          {% if block.type == 'menu_item' %}
            <li class="menu-item" data-menu-item data-block-index="{{ forloop.index0 }}">
              {% if block.settings.collection != blank %}
                <a href="/collections/all-products?collection={{ block.settings.collection.handle }}" class="menu-link">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                  <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </a>
              {% elsif block.settings.custom_link != blank %}
                <a href="{{ block.settings.custom_link }}" class="menu-link">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                  <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </a>
              {% else %}
                <a href="#" class="menu-link">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                  <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    {%- comment -%} Column 3: Search Button {%- endcomment -%}
    <div class="mega-menu-search">
      <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
        <div class="search-button">
          <input 
            type="search" 
            name="q" 
            class="search-input" 
            placeholder="Search..."
            autocomplete="off"
          />
          <button type="submit" class="search-icon-button" aria-label="Search">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <circle cx="11" cy="11" r="8" stroke-width="2"/>
              <path d="M21 21l-4.35-4.35" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </form>
    </div>

    {%- comment -%} Mobile Controls Wrapper - Contains burger menu and search on mobile {%- endcomment -%}
    <div class="mobile-controls-wrapper">
      {%- comment -%} Search for mobile - now on the LEFT {%- endcomment -%}
      <div class="mega-menu-search-mobile">
        <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
          <div class="search-button">
            <input 
              type="search" 
              name="q" 
              class="search-input" 
              placeholder="Search..."
              autocomplete="off"
            />
            <button type="submit" class="search-icon-button" aria-label="Search">
              <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <circle cx="11" cy="11" r="8" stroke-width="2"/>
                <path d="M21 21l-4.35-4.35" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </form>
      </div>

      {%- comment -%} Burger menu - now on the RIGHT {%- endcomment -%}
      <div class="mobile-trigger-bar" data-mobile-trigger-bar>
        <button class="hamburger-btn" type="button" aria-label="Open menu" aria-controls="mobileMenuDrawer" aria-expanded="false" data-hamburger>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>

  </div>


{%- comment -%} === Off-canvas Mobile Menu === {%- endcomment -%}
<div class="mobile-menu-overlay" data-mobile-overlay hidden></div>

<aside id="mobileMenuDrawer" class="mobile-menu-drawer" aria-hidden="true" role="dialog" aria-modal="true" data-mobile-drawer hidden>
  <div class="mobile-drawer-header">
    <span class="drawer-title">Menu</span>
    <button class="drawer-close" type="button" aria-label="Close menu" data-drawer-close>&times;</button>
  </div>

  <nav class="mobile-drawer-nav" role="navigation">
    <ul class="mobile-root-list">
      {% for block in section.blocks %}
        {% if block.type == 'menu_item' %}
          {% assign parent_index = forloop.index0 %}
          {% assign dropdown_type = block.settings.dropdown_type | default: 'collection' %}

          {% assign has_sub = false %}
          {% if dropdown_type == 'sub_items' %}
            {% assign next_index = parent_index | plus: 1 %}
            {% for check in section.blocks offset: next_index %}
              {% if check.type == 'menu_item' %}{% break %}{% endif %}
              {% if check.type == 'sub_item' %}{% assign has_sub = true %}{% break %}{% endif %}
            {% endfor %}
          {% endif %}

          <li class="mobile-root-item">
            {% if dropdown_type == 'all_collections' %}
              {%- comment -%} Quick Collections in Mobile {%- endcomment -%}
              <details class="mobile-accordion">
                <summary class="mobile-accordion-summary">
                  <span>
                    <span class="txt-en">{{ block.settings.menu_text }}</span>
                    <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                  </span>
                  <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <ul class="mobile-sub-list">
                  {% assign sorted_collections = collections | sort: 'title' %}
                  {% for collection in sorted_collections %}
                    {% unless collection.handle == 'frontpage' or collection.handle == 'all' %}
                      <li class="mobile-sub-item">
                        <a class="mobile-link" href="/collections/all-products?collection={{ collection.handle }}">{{ collection.title }} ({{ collection.products_count }})</a>
                      </li>
                    {% endunless %}
                  {% endfor %}
                </ul>
              </details>
            {% elsif has_sub %}
              <details class="mobile-accordion">
                <summary class="mobile-accordion-summary">
                  <span>
                    <span class="txt-en">{{ block.settings.menu_text }}</span>
                    <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                  </span>
                  <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <ul class="mobile-sub-list">
                  {% assign next_index = parent_index | plus: 1 %}
                  {% for sub in section.blocks offset: next_index %}
                    {% if sub.type == 'menu_item' %}{% break %}{% endif %}
                    {% if sub.type == 'sub_item' %}
                      <li class="mobile-sub-item">
                        {% if sub.settings.collection != blank %}
                          <a class="mobile-link" href="/collections/all-products?collection={{ sub.settings.collection.handle }}">
                            <span class="txt-en">{{ sub.settings.sub_item_text }}</span>
                            <span class="txt-ar">{% if sub.settings.sub_item_text_ar != blank %}{{ sub.settings.sub_item_text_ar }}{% else %}{{ sub.settings.sub_item_text }}{% endif %}</span>
                          </a>
                        {% else %}
                          <span class="mobile-link mobile-link--muted">
                            <span class="txt-en">{{ sub.settings.sub_item_text }}</span>
                            <span class="txt-ar">{% if sub.settings.sub_item_text_ar != blank %}{{ sub.settings.sub_item_text_ar }}{% else %}{{ sub.settings.sub_item_text }}{% endif %}</span>
                          </span>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </details>
            {% else %}
              {% if block.settings.collection != blank %}
                <a class="mobile-link" href="/collections/all-products?collection={{ block.settings.collection.handle }}">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                </a>
              {% elsif block.settings.custom_link != blank %}
                <a class="mobile-link" href="{{ block.settings.custom_link }}">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                </a>
              {% else %}
                <span class="mobile-link mobile-link--muted">
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                </span>
              {% endif %}
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </nav>
</aside>


  {%- comment -%} Dropdown Panels {%- endcomment -%}
  {% assign current_parent_index = -1 %}
  {% for block in section.blocks %}
    {% if block.type == 'menu_item' %}
      {% assign current_parent_index = forloop.index0 %}
      {% assign dropdown_type = block.settings.dropdown_type | default: 'collection' %}
      
      {%- comment -%} Check if there are sub-items following this menu item {%- endcomment -%}
      {% assign has_sub_items = false %}
      {% if dropdown_type == 'sub_items' %}
        {% assign next_index = forloop.index0 | plus: 1 %}
        {% for check_block in section.blocks offset: next_index %}
          {% if check_block.type == 'menu_item' %}
            {% break %}
          {% elsif check_block.type == 'sub_item' %}
            {% assign has_sub_items = true %}
            {% break %}
          {% endif %}
        {% endfor %}
      {% endif %}

      <div class="mega-dropdown {% if has_sub_items %}has-sub-items{% endif %}" data-dropdown-for="{{ forloop.index0 }}">
        <div class="mega-dropdown-inner">
          
          {% if has_sub_items %}
            {%- comment -%} TWO-LEVEL: Sub-Items on Left + Products on Right {%- endcomment -%}
            
            <div class="dropdown-nav">
              <h3 class="dropdown-title">
                <span class="txt-en">{{ block.settings.menu_text }}</span>
                <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
              </h3>
              <ul class="sub-items-list">
                {% assign next_index = forloop.index0 | plus: 1 %}
                {% for sub_block in section.blocks offset: next_index %}
                  {% if sub_block.type == 'menu_item' %}
                    {% break %}
                  {% elsif sub_block.type == 'sub_item' %}
                    <li class="sub-item" data-sub-item data-collection-id="{{ sub_block.settings.collection.id }}">
                      <a href="/collections/all-products?collection={{ sub_block.settings.collection.handle }}" class="sub-item-link">
                        <span class="txt-en">{{ sub_block.settings.sub_item_text }}</span>
                        <span class="txt-ar">{% if sub_block.settings.sub_item_text_ar != blank %}{{ sub_block.settings.sub_item_text_ar }}{% else %}{{ sub_block.settings.sub_item_text }}{% endif %}</span>
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                          <path d="M6 12l4-4-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </a>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>

            <div class="dropdown-products">
              {% assign next_index = forloop.index0 | plus: 1 %}
              {% for sub_block in section.blocks offset: next_index %}
                {% if sub_block.type == 'menu_item' %}
                  {% break %}
                {% elsif sub_block.type == 'sub_item' %}
                  <div class="products-section" data-products-for="{{ sub_block.settings.collection.id }}">
                    <div class="products-header">
                      <h4>{{ sub_block.settings.collection.title }}</h4>
                      <div class="dropdown-actions">
                        <a href="/collections/all-products?collection={{ sub_block.settings.collection.handle }}" class="view-all-link">
                          <span class="txt-en">View All ({{ sub_block.settings.collection.products_count }})</span>
                          <span class="txt-ar">عرض الكل ({{ sub_block.settings.collection.products_count }})</span>
                        </a>
                        <button class="close-dropdown-btn" aria-label="Close menu" type="button">
                          <span class="txt-en">Close <span class="close-x-icon">X</span></span>
                          <span class="txt-ar">إغلاق <span class="close-x-icon">X</span></span>
                        </button>
                      </div>
                    </div>
                    <div class="products-grid">
                      {% assign product_limit = section.settings.products_per_row | default: 4 %}
                      {% for product in sub_block.settings.collection.products limit: product_limit %}
                        <div class="product-card">
                          <a href="{{ product.url }}" class="product-link">
                            {% if product.featured_image %}
                              <div class="product-image">
                                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}" loading="lazy" width="250" height="250">
                              </div>
                            {% else %}
                              <div class="product-image product-image-placeholder">
                                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              </div>
                            {% endif %}
                            
                            <div class="product-info">
                              <h5 class="product-title">{{ product.title }}</h5>
                              <div class="product-price">
                                {% if product.compare_at_price > product.price %}
                                  <span class="price-sale">{{ product.price | money }}</span>
                                  <span class="price-compare">{{ product.compare_at_price | money }}</span>
                                {% else %}
                                  <span class="price">{{ product.price | money }}</span>
                                {% endif %}
                              </div>
                            </div>
                          </a>
                          <a href="{{ product.url }}" class="product-buy-button">
                            <span class="txt-en">{{ section.settings.buy_button_text | default: 'Buy Now' }}</span>
                            <span class="txt-ar">اشتري الآن</span>
                          </a>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

          {% elsif dropdown_type == 'collection' and block.settings.collection != blank %}
            {%- comment -%} SIMPLE: Direct Collection Products {%- endcomment -%}
            
            <div class="dropdown-simple">
              <div class="dropdown-header">
                <h3>{{ block.settings.collection.title }}</h3>
                <div class="dropdown-actions">
                  <a href="/collections/all-products?collection={{ block.settings.collection.handle }}" class="view-all-link">
                    <span class="txt-en">View All ({{ block.settings.collection.products_count }})</span>
                    <span class="txt-ar">عرض الكل ({{ block.settings.collection.products_count }})</span>
                  </a>
                  <button class="close-dropdown-btn" aria-label="Close menu" type="button">
                    <span class="txt-en">Close <span class="close-x-icon">X</span></span>
                    <span class="txt-ar">إغلاق <span class="close-x-icon">X</span></span>
                  </button>
                </div>
              </div>
              
              <div class="products-grid">
                {% assign product_limit = section.settings.products_per_row | default: 4 %}
                {% for product in block.settings.collection.products limit: product_limit %}
                  <div class="product-card">
                    <a href="{{ product.url }}" class="product-link">
                      {% if product.featured_image %}
                        <div class="product-image">
                          <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}" loading="lazy" width="250" height="250">
                        </div>
                      {% else %}
                        <div class="product-image product-image-placeholder">
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        </div>
                      {% endif %}
                      
                      <div class="product-info">
                        <h5 class="product-title">{{ product.title }}</h5>
                        <div class="product-price">
                          {% if product.compare_at_price > product.price %}
                            <span class="price-sale">{{ product.price | money }}</span>
                            <span class="price-compare">{{ product.compare_at_price | money }}</span>
                          {% else %}
                            <span class="price">{{ product.price | money }}</span>
                          {% endif %}
                        </div>
                      </div>
                    </a>
                    <a href="{{ product.url }}" class="product-buy-button">
                      <span class="txt-en">{{ section.settings.buy_button_text | default: 'Buy Now' }}</span>
                      <span class="txt-ar">اشتري الآن</span>
                    </a>
                  </div>
                {% endfor %}
              </div>
            </div>

          {% elsif dropdown_type == 'all_collections' %}
            {%- comment -%} QUICK COLLECTIONS: Display all store collections as rows {%- endcomment -%}
            
            <div class="dropdown-simple quick-collections-dropdown">
              <div class="dropdown-header">
                <h3>
                  <span class="txt-en">{{ block.settings.menu_text }}</span>
                  <span class="txt-ar">{% if block.settings.menu_text_ar != blank %}{{ block.settings.menu_text_ar }}{% else %}{{ block.settings.menu_text }}{% endif %}</span>
                </h3>
                <div class="dropdown-actions">
                  <button class="close-dropdown-btn" aria-label="Close menu" type="button">
                    <span class="txt-en">Close <span class="close-x-icon">X</span></span>
                    <span class="txt-ar">إغلاق <span class="close-x-icon">X</span></span>
                  </button>
                </div>
              </div>
              
              <div class="collections-rows-list">
                {% assign sorted_collections = collections | sort: 'title' %}
                {% for collection in sorted_collections %}
                  {% unless collection.handle == 'frontpage' or collection.handle == 'all' %}
                    <div class="collection-row-item">
                      <a href="/collections/all-products?collection={{ collection.handle }}" class="collection-row-link">
                        <span class="collection-name">{{ collection.title }}</span>
                        <span class="collection-count">({{ collection.products_count }})</span>
                      </a>
                    </div>
                  {% endunless %}
                {% endfor %}
              </div>
            </div>

          {% endif %}

        </div>
      </div>
    {% endif %}
  {% endfor %}

</div>

{%- comment -%} Page Overlay for Dropdowns - Must be outside wrapper for proper z-index stacking {%- endcomment -%}
<div class="mega-menu-page-overlay" data-page-overlay></div>

<style>
