    color: inherit !important;
  }

  /* ================ PERFORMANCE OPTIMIZATIONS ================ */
  /* PERFORMANCE: CSS Containment for better rendering isolation */
  .mega-menu-wrapper {
    contain: layout style !important;
  }
  
  .mega-dropdown {
    contain: layout style paint !important;
  }
  
  .product-card,
