    contain: layout style paint !important;
  }
  
  /* PERFORMANCE: GPU Acceleration with will-change hints */
  .mega-dropdown {
    will-change: opacity, transform !important;
  }
  
  .product-card:hover,
  .sub-item:hover,
  .menu-link:hover,
  .social-icon:hover,
