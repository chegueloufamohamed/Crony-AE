<script
  type="application/json"
  data-section-type="product-recommendations"
  data-section-id="{{ section.id }}"
>
</script>

{% comment %} Content settings {% endcomment %}
{%- assign product_recommendations_heading = section.settings.product_recommendations_heading -%}

{% comment %} End content settings {% endcomment %}

{% comment %} NE compatibility {% endcomment %}
{% comment%} This setting and conditional should be removed in the New Editor {% endcomment %}
{% if section.settings.show_product_recommendations %}
{% comment %} Ends NE compatibility {% endcomment %}

  {%- comment -%}
    1) Resolve complementary metafield (standard Shopify definition)
       Namespace: shopify--discovery--product_recommendation
       Key: complementary_products
  {%- endcomment -%}

  {%- assign complementary_meta = product.metafields["shopify--discovery--product_recommendation"]["complementary_products"] -%}
  {%- if complementary_meta and complementary_meta.value != blank -%}
    {%- assign complementary_list = complementary_meta.value -%}
  {%- else -%}
    {%- assign complementary_list = nil -%}
  {%- endif -%}

  {% comment %} Check whether product has any tags for custom related products {% endcomment %}
  {% for tag in product.tags %}
    {% if tag contains 'meta-related-collection-' %}
      {% assign related_collection_handle = tag | remove: 'meta-related-collection-' %}
    {% endif %}
  {% endfor %}

  {% if related_collection_handle != blank %}
    {% comment %} Show products based on merchant-added tags prepended with 'meta-related-collection-' {% endcomment %}
    {% assign collection_size = collections[related_collection_handle].all_products_count %}

    {% if collection_size > 0 %}
      {% assign custom_collection = collections[related_collection_handle] %}
      {% assign products = custom_collection.products %}
    {% endif %}

    {% if custom_collection and collection_size > 0 %}
      {% assign show_custom_collection = true %}
    {% endif %}

  {% else %}
    {% comment %} Shopify generated dynamic recommendations, falling back to default related products (based on parent collection) {% endcomment %}
    {% assign dynamic_collection = recommendations %}
    {% assign products = recommendations.products %}
    {% assign show_dynamic_collection = true %}
  {% endif %}

  {%- comment -%}
    2) Build final products list with priority:
       a) complementary metafield items (if any)
       b) fallback Helmet + Iron-Man Bag
       c) base products from custom/dynamic collection
       Target count: 2
  {%- endcomment -%}

  {%- assign base_products = products -%}
  {%- assign final_products = "" | split: "" -%}

  {%- comment -%}
    a) Add complementary metafield items first (if present)
  {%- endcomment -%}
  {% if complementary_list %}
    {% for p in complementary_list %}
      {% if p and p.id != product.id %}
        {% assign final_products = final_products | concat: p %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {%- comment -%}
    b) Add hard fallback products (Helmet + Bag) until we reach 2
  {%- endcomment -%}
  {% if final_products.size < 2 %}
    {% assign helmet = all_products["crony-scooter-safety-helmet-bicycle-helmets-matte-black-men-women-bike-mountain-road-bike-integrally-molded-cycling-adjustable-bike-helmets"] %}
    {% if helmet and helmet.id != product.id %}
      {% assign final_products = final_products | concat: helmet %}
    {% endif %}
  {% endif %}

  {% if final_products.size < 2 %}
    {% assign bag = all_products["crony-iron-man-led-display-backpack-upgrade-iron-man-led-backpack-screen-knight-motorcycle-backpack-cool-travel-bag-scooter-bag"] %}
    {% if bag and bag.id != product.id %}
      {% assign final_products = final_products | concat: bag %}
    {% endif %}
  {% endif %}

  {%- comment -%}
    c) If still less than 2, top up from original products (custom/dynamic)
  {%- endcomment -%}
  {% if final_products.size < 2 and base_products %}
    {% for p in base_products %}
      {% if p and p.id != product.id %}
        {% assign final_products = final_products | concat: p %}
      {% endif %}
      {% if final_products.size >= 2 %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign products = final_products | slice: 0, 2 %}

  {% comment %} HTML markup {% endcomment %}
  {% capture product_collections_markup %}
    <div class="recommended-products__title" data-recommended-product-count="{{ products.size }}">
      <h2 class="title center">{{ section.settings.product_recommendations_heading }}</h2>
      <div class="feature-divider"></div>
    </div>

    {% if section.settings.product_recommendations_style == 'slider' %}
      {% comment %} Recommended Products Slider {% endcomment %}
      <div class="recommended-products--slider js-recommended-products-slider">
        {%
          render 'product-slider',
          limit: section.settings.recommended_products_limit,
          products: products,
          per_slide: section.settings.products_per_row - 1,
          skip_product: product,
        %}
      </div>
    {% else %}
      {% comment %} Recommended Products Grid {% endcomment %}
      <div class="recommended-products--grid">
        <div class="container">
          {%
            render 'product-loop',
            limit: section.settings.recommended_products_limit,
            products: products,
            skip_product: product,
            products_per_row: section.settings.products_per_row,
          %}
        </div>
      </div>
    {% endif %}
  {% endcapture %}

  <section
    class="
      section
      {% if section.settings.wide_display == true %}
        is-width-wide
      {% endif %}
    "
  >
    <div class="container">
      <div class="one-whole column">
        {% if show_custom_collection %}
          <div
            class="
              product-recommendations
              product-recommendations--{{ template | replace: '.', '-' | handle }}
              meta-related-recommended-collection
            "
            data-product-recommendations
            data-enabled="{{ section.settings.show_product_recommendations }}"
          >
            {{ product_collections_markup }}
          </div>
        {% elsif show_dynamic_collection %}
          <div
            class="
              product-recommendations
              product-recommendations--{{ template | replace: '.', '-' | handle }}
            "
            data-product-recommendations
            data-section-id="{{ section.id }}"
            data-recommendations-url="{{ routes.product_recommendations_url }}"
            data-product-id="{{ product.id }}"
            data-limit="{{ section.settings.recommended_products_limit }}"
            data-enabled="{{ section.settings.show_product_recommendations }}"
          >
            {{ product_collections_markup }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Related products",
  "class": "shopify-section--recommended-products",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_product_recommendations",
      "label": "Show dynamic recommendations",
      "info": "Dynamic recommendations change and improve with time. [Learn more](https://help.shopify.com/en/themes/development/recommended-products)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "wide_display",
      "label": "Wide display",
      "default": false
    },
    {
      "type": "radio",
      "id": "product_recommendations_style",
      "label": "Layout",
      "default": "grid",
      "options": [
        {
          "value": "slider",
          "label": "Slider"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ]
    },
    {
      "type": "text",
      "id": "product_recommendations_heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "recommended_products_limit",
      "label": "Limit products",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
