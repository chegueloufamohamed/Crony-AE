{% doc %}
  @prompt
    creat featured collection slideshow, where I can choose which collection to show, number of products per row and view all button under them, the product card should have photo of the product first, title, price and crossed price next to each other then buy now button, however the button takes to the product page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.section_bg_color }};
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-featured-collection__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
  }

  .ai-featured-collection__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-featured-collection__slideshow-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .ai-featured-collection__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.4s ease;
  }

  .ai-featured-collection__slide-{{ ai_gen_id }} {
    flex: 0 0 auto;
    padding: 0 10px;
    box-sizing: border-box;
  }

  .ai-featured-collection__product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .ai-featured-collection__product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-featured-collection__product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-collection__product-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-featured-collection__product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-collection__product-info-{{ ai_gen_id }} {
    padding: 15px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-featured-collection__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 10px;
    font-weight: 600;
    line-height: 1.35;
    /* --- 2-line clamp with ellipsis --- */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: calc(2 * 1em * 1.35);
  }

  .ai-featured-collection__product-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  /* Neutralize hover color (no white-on-hover) */
  .ai-featured-collection__product-title-link-{{ ai_gen_id }}:hover {
    color: inherit;
  }

  .ai-featured-collection__product-prices-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 15px;
  }

  .ai-featured-collection__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-featured-collection__product-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-featured-collection__buy-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    margin-top: auto;
  }

  .ai-featured-collection__buy-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-featured-collection__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .ai-featured-collection__nav-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-featured-collection__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
  }

  .ai-featured-collection__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-featured-collection__view-all-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-featured-collection__view-all-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 40px;
    background-color: {{ block.settings.view_all_bg_color }};
    color: {{ block.settings.view_all_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-featured-collection__view-all-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_bg_color }};
  }

  .ai-featured-collection__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  @media screen and (max-width: 768px) {
    .ai-featured-collection__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-featured-collection__product-info-{{ ai_gen_id }} {
      padding: 12px;
    }
  }
{% endstyle %}

<featured-collection-slideshow-{{ ai_gen_id }}
  class="ai-featured-collection-{{ ai_gen_id }}"
  data-products-per-row="{{ block.settings.products_per_row }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.description != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-featured-collection__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-featured-collection__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      {% assign collection = block.settings.collection %}
      {% if collection.products.size > 0 %}
        <div class="ai-featured-collection__slideshow-{{ ai_gen_id }}">
          <div class="ai-featured-collection__track-{{ ai_gen_id }}">
            {% for product in collection.products limit: 20 %}
              <div class="ai-featured-collection__slide-{{ ai_gen_id }}">
                <div class="ai-featured-collection__product-card-{{ ai_gen_id }}">
                  <a href="{{ product.url }}" class="ai-featured-collection__product-image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}
"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-featured-collection__product-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      <div class="ai-featured-collection__product-image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </a>

                  <div class="ai-featured-collection__product-info-{{ ai_gen_id }}">
                    <h3 class="ai-featured-collection__product-title-{{ ai_gen_id }}">
                      <a href="{{ product.url }}" class="ai-featured-collection__product-title-link-{{ ai_gen_id }}">
                        {{ product.title }}
                      </a>
                    </h3>

                    <div class="ai-featured-collection__product-prices-{{ ai_gen_id }}">
                      <span class="ai-featured-collection__product-price-{{ ai_gen_id }}">
                        {{ product.price | money }}
                      </span>
                      {% if product.compare_at_price > product.price %}
                        <span class="ai-featured-collection__product-compare-price-{{ ai_gen_id }}">
                          {{ product.compare_at_price | money }}
                        </span>
                      {% endif %}
                    </div>

                    <a href="{{ product.url }}" class="ai-featured-collection__buy-button-{{ ai_gen_id }}">
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="ai-featured-collection__nav-{{ ai_gen_id }}">
          <button
            class="ai-featured-collection__nav-button-{{ ai_gen_id }} ai-featured-collection__nav-prev-{{ ai_gen_id }}"
            aria-label="Previous"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button
            class="ai-featured-collection__nav-button-{{ ai_gen_id }} ai-featured-collection__nav-next-{{ ai_gen_id }}"
            aria-label="Next"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>

        {% if block.settings.show_view_all %}
          <div class="ai-featured-collection__view-all-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-featured-collection__view-all-button-{{ ai_gen_id }}">
              {{ block.settings.view_all_text }}
            </a>
          </div>
        {% endif %}
      {% else %}
        <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}">
          <p>This collection is empty. Add products to display them here.</p>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}">
        <p>Next, select a collection to display</p>
      </div>
    {% endif %}
  </div>
</featured-collection-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollectionSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.productsPerRow = parseInt(this.dataset.productsPerRow) || 4;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-featured-collection__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-featured-collection__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-featured-collection__nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-featured-collection__nav-next-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.setupSlides();
        this.setupEventListeners();
        this.updateButtons();

        window.addEventListener('resize', () => {
          this.setupSlides();
          this.updateSlidePosition();
        });
      }

      setupSlides() {
        const containerWidth = this.track.parentElement.offsetWidth;
        const gap = 20;
        const slideWidth = (containerWidth - (gap * (this.productsPerRow - 1))) / this.productsPerRow;

        this.slides.forEach(slide => {
          slide.style.width = slideWidth + 'px';
        });

        this.maxIndex = Math.max(0, this.slides.length - this.productsPerRow);
      }

      setupEventListeners() {
        if (this.prevButton) this.prevButton.addEventListener('click', () => this.prev());
        if (this.nextButton) this.nextButton.addEventListener('click', () => this.next());
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlidePosition();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateSlidePosition();
        }
      }

      updateSlidePosition() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = 20;
        const offset = -(this.currentIndex * (slideWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        if (this.prevButton) this.prevButton.disabled = this.currentIndex === 0;
        if (this.nextButton) this.nextButton.disabled = this.currentIndex >= this.maxIndex;
      }
    }

    customElements.define('featured-collection-slideshow-{{ ai_gen_id }}', FeaturedCollectionSlideshow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection slideshow",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_per_row", "min": 2, "max": 6, "step": 1, "label": "Products per row", "default": 4 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured collection" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Buy now" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all button", "default": true },
    { "type": "text", "id": "view_all_text", "label": "View all button text", "default": "View all" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg_color", "label": "Section background", "default": "#f6f7f9" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#333333" },
    { "type": "color", "id": "text_color", "label": "Description", "default": "#666666" },
    { "type": "color", "id": "card_bg_color", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border_color", "label": "Card border", "default": "#e0e0e0" },
    { "type": "color", "id": "product_title_color", "label": "Product title", "default": "#333333" },
    { "type": "color", "id": "link_hover_color", "label": "Product title hover", "default": "#03a196" },
    { "type": "color", "id": "price_color", "label": "Price", "default": "#333333" },
    { "type": "color", "id": "compare_price_color", "label": "Compare at price", "default": "#999999" },
    { "type": "color", "id": "button_bg_color", "label": "Button background", "default": "#1b1f23" },
    { "type": "color", "id": "button_hover_bg_color", "label": "Button hover", "default": "#5ec6ff" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#ffffff" },
    { "type": "color", "id": "view_all_bg_color", "label": "View all background", "default": "#1b1f23" },
    { "type": "color", "id": "view_all_hover_bg_color", "label": "View all hover", "default": "#5ec6ff" },
    { "type": "color", "id": "view_all_text_color", "label": "View all text", "default": "#ffffff" },
    { "type": "color", "id": "arrow_bg_color", "label": "Arrow background", "default": "#1b1f23" },
    { "type": "color", "id": "arrow_hover_bg_color", "label": "Arrow hover", "default": "#5ec6ff" },
    { "type": "color", "id": "arrow_color", "label": "Arrow icon", "default": "#ffffff" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "min": 20, "max": 60, "step": 2, "unit": "px", "label": "Heading size", "default": 36 },
    { "type": "range", "id": "text_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Description size", "default": 16 },
    { "type": "range", "id": "product_title_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Product title size", "default": 16 },
    { "type": "range", "id": "price_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Price size", "default": 16 },
    { "type": "range", "id": "button_text_size", "min": 12, "max": 20, "step": 1, "unit": "px", "label": "Button text size", "default": 14 },

    { "type": "header", "content": "Style" },
    { "type": "range", "id": "card_border_radius", "min": 0, "max": 20, "step": 2, "unit": "px", "label": "Card border radius", "default": 8 },
    { "type": "range", "id": "button_border_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "label": "Button border radius", "default": 4 }
  ],
  "presets": [
    { "name": "Collection slideshow" }
  ]
}
{% endschema %}
