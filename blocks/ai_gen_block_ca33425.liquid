{% doc %}
  @prompt
    create recently viewed section, it should be either slider or grid, if slider it can be swiped left or right using the cursor or finger on the mobile, the product card should have product photo, title, price and crossed price then buy now button but takes to the product page of that product, in the schema it should be each item them under it all of its setting like typology, color, padding, radiaus hover, etc, then the other items then its setting and so on, the slider arrows setting too, view all button at the end and allignment of all items whether right, left or center
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recently-viewed-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-recently-viewed-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-recently-viewed-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.heading_spacing }}px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .ai-recently-viewed-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-align: {{ block.settings.content_alignment }};
    flex: 1;
  }

  .ai-recently-viewed-view-all-{{ ai_gen_id }} {
    padding: {{ block.settings.view_all_padding_vertical }}px {{ block.settings.view_all_padding_horizontal }}px;
    background-color: {{ block.settings.view_all_bg_color }};
    color: {{ block.settings.view_all_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.view_all_border_radius }}px;
    font-size: {{ block.settings.view_all_font_size }}px;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-recently-viewed-view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_bg_color }};
    color: {{ block.settings.view_all_hover_text_color }};
  }

  .ai-recently-viewed-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  {% if block.settings.layout == 'slider' %}
    .ai-recently-viewed-slider-{{ ai_gen_id }} {
      overflow: hidden;
      cursor: grab;
      user-select: none;
    }

    .ai-recently-viewed-slider-{{ ai_gen_id }}:active {
      cursor: grabbing;
    }

    .ai-recently-viewed-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.product_gap }}px;
      transition: transform 0.3s ease;
    }

    .ai-recently-viewed-product-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.products_per_row }} - 1) * {{ block.settings.product_gap }}px) / {{ block.settings.products_per_row }});
      min-width: 0;
    }

    .ai-recently-viewed-arrow-{{ ai_gen_id }} {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: {{ block.settings.arrow_size }}px;
      height: {{ block.settings.arrow_size }}px;
      background-color: {{ block.settings.arrow_bg_color }};
      color: {{ block.settings.arrow_color }};
      border: none;
      border-radius: {{ block.settings.arrow_border_radius }}px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      transition: all 0.3s ease;
      opacity: {{ block.settings.arrow_opacity }};
    }

    .ai-recently-viewed-arrow-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.arrow_hover_bg_color }};
      color: {{ block.settings.arrow_hover_color }};
      opacity: 1;
    }

    .ai-recently-viewed-arrow-{{ ai_gen_id }}:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .ai-recently-viewed-arrow-left-{{ ai_gen_id }} {
      left: {{ block.settings.arrow_position }}px;
    }

    .ai-recently-viewed-arrow-right-{{ ai_gen_id }} {
      right: {{ block.settings.arrow_position }}px;
    }

    .ai-recently-viewed-arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }

    @media screen and (max-width: 768px) {
      .ai-recently-viewed-product-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - {{ block.settings.product_gap }}px) / 2);
      }

      .ai-recently-viewed-arrow-{{ ai_gen_id }} {
        width: {{ block.settings.arrow_size | times: 0.8 }}px;
        height: {{ block.settings.arrow_size | times: 0.8 }}px;
      }
    }
  {% else %}
    .ai-recently-viewed-grid-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
      gap: {{ block.settings.product_gap }}px;
    }

    @media screen and (max-width: 768px) {
      .ai-recently-viewed-grid-{{ ai_gen_id }} {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  {% endif %}

  .ai-recently-viewed-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-recently-viewed-card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_lift }}px);
    box-shadow: 0 {{ block.settings.card_hover_shadow }}px {{ block.settings.card_hover_shadow | times: 2 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-recently-viewed-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_spacing }}px;
  }

  .ai-recently-viewed-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recently-viewed-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.content_alignment }};
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-recently-viewed-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    text-decoration: none;
    display: block;
  }

  .ai-recently-viewed-product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-recently-viewed-price-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.price_spacing }}px;
  }

  .ai-recently-viewed-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: bold;
  }

  .ai-recently-viewed-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    margin-left: 8px;
  }

  .ai-recently-viewed-buy-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
    margin-top: auto;
  }

  .ai-recently-viewed-buy-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-recently-viewed-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.heading_color }};
  }
{% endstyle %}

<recently-viewed-{{ ai_gen_id }} class="ai-recently-viewed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-recently-viewed-container-{{ ai_gen_id }}">
    <div class="ai-recently-viewed-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-recently-viewed-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.show_view_all and block.settings.view_all_link != blank %}
        <a href="{{ block.settings.view_all_link }}" class="ai-recently-viewed-view-all-{{ ai_gen_id }}">
          {{ block.settings.view_all_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-recently-viewed-wrapper-{{ ai_gen_id }}">
      {% if block.settings.layout == 'slider' %}
        <button class="ai-recently-viewed-arrow-{{ ai_gen_id }} ai-recently-viewed-arrow-left-{{ ai_gen_id }}" aria-label="Previous">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-recently-viewed-slider-{{ ai_gen_id }}">
          <div class="ai-recently-viewed-track-{{ ai_gen_id }}">
          </div>
        </div>

        <button class="ai-recently-viewed-arrow-{{ ai_gen_id }} ai-recently-viewed-arrow-right-{{ ai_gen_id }}" aria-label="Next">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% else %}
        <div class="ai-recently-viewed-grid-{{ ai_gen_id }}">
        </div>
      {% endif %}
    </div>

    <div class="ai-recently-viewed-empty-{{ ai_gen_id }}" style="display: none;">
      {{ block.settings.empty_message }}
    </div>
  </div>
</recently-viewed-{{ ai_gen_id }}>

<script>
  (function() {
    class RecentlyViewed{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.maxProducts = {{ block.settings.max_products }};
        this.layout = '{{ block.settings.layout }}';
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.animationID = 0;
      }

      connectedCallback() {
        this.container = this.layout === 'slider' 
          ? this.querySelector('.ai-recently-viewed-track-{{ ai_gen_id }}')
          : this.querySelector('.ai-recently-viewed-grid-{{ ai_gen_id }}');
        this.emptyState = this.querySelector('.ai-recently-viewed-empty-{{ ai_gen_id }}');
        
        if (this.layout === 'slider') {
          this.slider = this.querySelector('.ai-recently-viewed-slider-{{ ai_gen_id }}');
          this.prevBtn = this.querySelector('.ai-recently-viewed-arrow-left-{{ ai_gen_id }}');
          this.nextBtn = this.querySelector('.ai-recently-viewed-arrow-right-{{ ai_gen_id }}');
          this.setupSlider();
        }

        this.loadRecentlyViewed();
        this.saveCurrentProduct();
      }

      saveCurrentProduct() {
        if (window.location.pathname.includes('/products/')) {
          const productHandle = window.location.pathname.split('/products/')[1].split('?')[0];
          
          fetch(`/products/${productHandle}.js`)
            .then(response => response.json())
            .then(product => {
              let recentlyViewed = this.getRecentlyViewed();
              recentlyViewed = recentlyViewed.filter(handle => handle !== productHandle);
              recentlyViewed.unshift(productHandle);
              recentlyViewed = recentlyViewed.slice(0, this.maxProducts);
              localStorage.setItem('recentlyViewedProducts', JSON.stringify(recentlyViewed));
            });
        }
      }

      getRecentlyViewed() {
        const stored = localStorage.getItem('recentlyViewedProducts');
        return stored ? JSON.parse(stored) : [];
      }

      loadRecentlyViewed() {
        let handles = this.getRecentlyViewed();
        
        if (window.location.pathname.includes('/products/')) {
          const currentHandle = window.location.pathname.split('/products/')[1].split('?')[0];
          handles = handles.filter(handle => handle !== currentHandle);
        }

        if (handles.length === 0) {
          this.emptyState.style.display = 'block';
          if (this.layout === 'slider') {
            this.querySelector('.ai-recently-viewed-wrapper-{{ ai_gen_id }}').style.display = 'none';
          }
          return;
        }

        const promises = handles.map(handle => 
          fetch(`/products/${handle}.js`)
            .then(response => response.json())
            .catch(() => null)
        );

        Promise.all(promises).then(products => {
          const validProducts = products.filter(p => p !== null);
          
          if (validProducts.length === 0) {
            this.emptyState.style.display = 'block';
            if (this.layout === 'slider') {
              this.querySelector('.ai-recently-viewed-wrapper-{{ ai_gen_id }}').style.display = 'none';
            }
            return;
          }

          validProducts.forEach(product => {
            this.container.appendChild(this.createProductCard(product));
          });

          if (this.layout === 'slider') {
            this.updateSliderButtons();
          }
        });
      }

      createProductCard(product) {
        const card = document.createElement('div');
        card.className = this.layout === 'slider' 
          ? 'ai-recently-viewed-product-{{ ai_gen_id }}'
          : '';

        const price = product.price / 100;
        const comparePrice = product.compare_at_price ? product.compare_at_price / 100 : null;

        card.innerHTML = `
          <div class="ai-recently-viewed-card-{{ ai_gen_id }}">
            <div class="ai-recently-viewed-image-wrapper-{{ ai_gen_id }}">
              <img 
                src="${product.featured_image}" 
                alt="${product.title}"
                class="ai-recently-viewed-image-{{ ai_gen_id }}"
                loading="lazy"
              >
            </div>
            <div class="ai-recently-viewed-content-{{ ai_gen_id }}">
              <a href="/products/${product.handle}" class="ai-recently-viewed-product-title-{{ ai_gen_id }}">
                ${product.title}
              </a>
              <div class="ai-recently-viewed-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-recently-viewed-price-{{ ai_gen_id }}">
                  ${Shopify.formatMoney(product.price, '{{ cart.currency.symbol }}{{amount}}')}
                </span>
                ${comparePrice ? `
                  <span class="ai-recently-viewed-compare-price-{{ ai_gen_id }}">
                    ${Shopify.formatMoney(product.compare_at_price, '{{ cart.currency.symbol }}{{amount}}')}
                  </span>
                ` : ''}
              </div>
              <a href="/products/${product.handle}" class="ai-recently-viewed-buy-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        `;

        return card;
      }

      setupSlider() {
        this.prevBtn.addEventListener('click', () => this.slide('prev'));
        this.nextBtn.addEventListener('click', () => this.slide('next'));

        this.slider.addEventListener('mousedown', this.touchStart.bind(this));
        this.slider.addEventListener('touchstart', this.touchStart.bind(this));
        this.slider.addEventListener('mouseup', this.touchEnd.bind(this));
        this.slider.addEventListener('touchend', this.touchEnd.bind(this));
        this.slider.addEventListener('mousemove', this.touchMove.bind(this));
        this.slider.addEventListener('touchmove', this.touchMove.bind(this));
        this.slider.addEventListener('mouseleave', this.touchEnd.bind(this));
      }

      slide(direction) {
        const itemsPerView = window.innerWidth <= 768 ? 2 : {{ block.settings.products_per_row }};
        const totalItems = this.container.children.length;
        const maxIndex = Math.max(0, totalItems - itemsPerView);

        if (direction === 'next') {
          this.currentIndex = Math.min(this.currentIndex + 1, maxIndex);
        } else {
          this.currentIndex = Math.max(this.currentIndex - 1, 0);
        }

        this.updateSliderPosition();
        this.updateSliderButtons();
      }

      updateSliderPosition() {
        const itemWidth = this.container.children[0]?.offsetWidth || 0;
        const gap = {{ block.settings.product_gap }};
        const offset = -(this.currentIndex * (itemWidth + gap));
        this.container.style.transform = `translateX(${offset}px)`;
      }

      updateSliderButtons() {
        const itemsPerView = window.innerWidth <= 768 ? 2 : {{ block.settings.products_per_row }};
        const totalItems = this.container.children.length;
        const maxIndex = Math.max(0, totalItems - itemsPerView);

        this.prevBtn.disabled = this.currentIndex === 0;
        this.nextBtn.disabled = this.currentIndex >= maxIndex;
      }

      touchStart(event) {
        this.isDragging = true;
        this.startPos = this.getPositionX(event);
        this.animationID = requestAnimationFrame(this.animation.bind(this));
        this.slider.style.cursor = 'grabbing';
      }

      touchMove(event) {
        if (this.isDragging) {
          const currentPosition = this.getPositionX(event);
          this.currentTranslate = this.prevTranslate + currentPosition - this.startPos;
        }
      }

      touchEnd() {
        this.isDragging = false;
        cancelAnimationFrame(this.animationID);
        
        const movedBy = this.currentTranslate - this.prevTranslate;
        
        if (movedBy < -50 && this.currentIndex < this.container.children.length - 1) {
          this.slide('next');
        }
        
        if (movedBy > 50 && this.currentIndex > 0) {
          this.slide('prev');
        }

        this.prevTranslate = this.currentTranslate;
        this.slider.style.cursor = 'grab';
      }

      getPositionX(event) {
        return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
      }

      animation() {
        if (this.isDragging) {
          requestAnimationFrame(this.animation.bind(this));
        }
      }
    }

    customElements.define('recently-viewed-{{ ai_gen_id }}', RecentlyViewed{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Recently viewed products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "slider",
          "label": "Slider"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Maximum products to show",
      "default": 8
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row",
      "default": 4
    },
    {
      "type": "range",
      "id": "product_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Gap between products",
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "inline_richtext",
      "id": "empty_message",
      "label": "Empty state message",
      "default": "No recently viewed products"
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Background color",
      "default": "#f6f7f9"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Padding top",
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Padding bottom",
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "label": "Font size",
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Spacing below heading",
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 30,
      "step": 2,
      "label": "Padding",
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "label": "Border radius",
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_hover_lift",
      "min": -10,
      "max": 0,
      "step": 1,
      "label": "Hover lift",
      "unit": "px",
      "default": -5
    },
    {
      "type": "range",
      "id": "card_hover_shadow",
      "min": 0,
      "max": 20,
      "step": 2,
      "label": "Hover shadow",
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "label": "Border radius",
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_spacing",
      "min": 5,
      "max": 30,
      "step": 1,
      "label": "Spacing below image",
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Product title"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Font size",
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "title_hover_color",
      "label": "Hover color",
      "default": "#03a196"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 5,
