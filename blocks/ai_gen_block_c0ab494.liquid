{% doc %}
  @prompt
    Generate a section to put in it a hero banner, it should have the hero banner upload for both mobile and desktop, it should have a heading text, subheading and a button that can be linked to collections, it also should have color overlay to apply it on, any text inserted it should have its setting like center it, right left, , add the position settings for all the items on the hero banner like the heading subheading and the button, where I can push them up or down, right or left 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;


  }

  .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-hero-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-hero-banner__image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 40px;
    z-index: 1;
  }

  .ai-hero-banner__inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    text-align: {{ block.settings.text_alignment }};
    width: 100%;
    max-width: 1200px;
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    max-width: 800px;
    position: relative;
    top: {{ block.settings.heading_vertical_position }}px;
    {% if block.settings.text_alignment == 'flex-start' %}
      left: {{ block.settings.heading_horizontal_position }}px;
    {% elsif block.settings.text_alignment == 'flex-end' %}
      right: {{ block.settings.heading_horizontal_position }}px;
    {% else %}
      left: {{ block.settings.heading_horizontal_position }}px;
    {% endif %}
  }

  .ai-hero-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 16px 0 0;
    max-width: 600px;
    position: relative;
    top: {{ block.settings.subheading_vertical_position }}px;
    {% if block.settings.text_alignment == 'flex-start' %}
      left: {{ block.settings.subheading_horizontal_position }}px;
    {% elsif block.settings.text_alignment == 'flex-end' %}
      right: {{ block.settings.subheading_horizontal_position }}px;
    {% else %}
      left: {{ block.settings.subheading_horizontal_position }}px;
    {% endif %}
  }

  .ai-hero-banner__button-wrapper-{{ ai_gen_id }} {
    margin-top: 24px;
    position: relative;
    top: {{ block.settings.button_vertical_position }}px;
    {% if block.settings.text_alignment == 'flex-start' %}
      left: {{ block.settings.button_horizontal_position }}px;
    {% elsif block.settings.text_alignment == 'flex-end' %}
      right: {{ block.settings.button_horizontal_position }}px;
    {% else %}
      left: {{ block.settings.button_horizontal_position }}px;
    {% endif %}
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-hero-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-hero-banner__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-hero-banner__image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-banner__image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      top: 40% !important;
      padding: 20px;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 }}px;
      margin-top: 12px;
    }

    .ai-hero-banner__button-wrapper-{{ ai_gen_id }} {
      margin-top: 16px;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image or block.settings.mobile_image %}
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-hero-banner__image-{{ ai_gen_id }} ai-hero-banner__image-desktop-{{ ai_gen_id }}"
        >
      {% endif %}

      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-hero-banner__image-{{ ai_gen_id }} ai-hero-banner__image-mobile-{{ ai_gen_id }}"
        >
      {% elsif block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-hero-banner__image-{{ ai_gen_id }} ai-hero-banner__image-mobile-{{ ai_gen_id }}"
        >
      {% endif %}
    {% else %}
      <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
          Next, add a hero banner image
        </div>
      </div>
    {% endif %}

    {% if block.settings.enable_overlay %}
      <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-banner__content-{{ ai_gen_id }}">
      <div class="ai-hero-banner__inner-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.subheading != blank %}
          <div class="ai-hero-banner__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <div class="ai-hero-banner__button-wrapper-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.button_link }}"
              class="ai-hero-banner__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 300,
      "max": 1500,
      "step": 50,
      "unit": "px",
      "label": "Desktop height",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our amazing collection"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Heading position"
    },
    {
      "type": "range",
      "id": "heading_vertical_position",
      "min": -500,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Vertical position",
      "default": 0,
      "info": "Negative moves up, positive moves down"
    },
    {
      "type": "range",
      "id": "heading_horizontal_position",
      "min": -200,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal position",
      "default": 0,
      "info": "Negative moves left, positive moves right"
    },
    {
      "type": "header",
      "content": "Subheading style"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subheading size",
      "default": 20
    },
    {
      "type": "header",
      "content": "Subheading position"
    },
    {
      "type": "range",
      "id": "subheading_vertical_position",
      "min": -600,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Vertical position",
      "default": 0,
      "info": "Negative moves up, positive moves down"
    },
    {
      "type": "range",
      "id": "subheading_horizontal_position",
      "min": -600,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal position",
      "default": 0,
      "info": "Negative moves left, positive moves right"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#03a196"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#03857c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Button position"
    },
    {
      "type": "range",
      "id": "button_vertical_position",
      "min": -600,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Vertical position",
      "default": 0,
      "info": "Negative moves up, positive moves down"
    },
    {
      "type": "range",
      "id": "button_horizontal_position",
      "min": -200,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal position",
      "default": 0,
      "info": "Negative moves left, positive moves right"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
