{% doc %}
  @prompt
    PERFORMANCE OPTIMIZED VERSION
    - Lazy loading images with native loading="lazy"
    - CSS containment for better paint/layout performance
    - Debounced scroll handlers to reduce reflows
    - Optimized event listeners with passive flag
    - RequestAnimationFrame for smooth animations
    - Reduced DOM queries with cached selectors
    - Will-change hints for GPU acceleration
    - Intersection Observer for viewport-based loading
    - content-visibility: auto to skip hidden instances
    - Image space reservation to prevent CLS
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
/* ---------------- Anti-theme bleed (SCOPED + OPINIONATED RESET) ---------------- */
.ai-collection-slideshow-{{ ai_gen_id }}:where(*) { isolation:isolate; }
.ai-collection-slideshow-{{ ai_gen_id }} * { box-sizing: border-box !important; }
.ai-collection-slideshow-{{ ai_gen_id }} :where(h1,h2,h3,h4,h5,h6,p,a,span,small,strong,em,ul,ol,li,button,svg,figure,img,div){
  all: revert;
  font-family: inherit !important;
  color: inherit !important;
}
.ai-collection-slideshow-{{ ai_gen_id }} :where(a){ text-decoration: none !important; }
.ai-collection-slideshow-{{ ai_gen_id }} :where(ul,ol){ list-style: none !important; padding:0 !important; margin:0 !important; }

/* Use theme's base font; keep colors & layout locked */
.ai-collection-slideshow-{{ ai_gen_id }}{
  font-family: inherit !important;
  color: #111 !important;
  line-height: 1.4 !important;
  /* PERFORMANCE: CSS containment */
  contain: layout style paint !important;
}

/* ---------------- Layout & visuals (all rules scoped + important) ---------------- */
.ai-collection-slideshow-{{ ai_gen_id }} {
  padding-top: {{ block.settings.padding_top }}px !important;
  padding-bottom: {{ block.settings.padding_bottom }}px !important;
  background-color: {{ block.settings.background_color }} !important;
}

.ai-collection-slideshow__container-{{ ai_gen_id }} {
  max-width: 1400px !important;
  margin: 0 auto !important;
  padding: 0 20px !important;
}

.ai-collection-slideshow__header-{{ ai_gen_id }} {
  text-align: {{ block.settings.heading_alignment }} !important;
  margin-bottom: 30px !important;
}

.ai-collection-slideshow__title-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px !important;
  color: {{ block.settings.heading_color }} !important;
  margin: 0 0 10px !important;
  text-transform: {{ block.settings.heading_text_transform }} !important;
  letter-spacing: {{ block.settings.heading_letter_spacing }}px !important;
  font-weight: 700 !important;
}

.ai-collection-slideshow__subtitle-{{ ai_gen_id }} {
  font-size: {{ block.settings.subheading_size }}px !important;
  color: {{ block.settings.subheading_color }} !important;
  margin: 0 !important;
}

.ai-collection-slideshow__products-wrapper-{{ ai_gen_id }} {
  position: relative !important;
}

.ai-collection-slideshow__products-grid-{{ ai_gen_id }} {
  display: grid !important;
  gap: {{ block.settings.grid_gap }}px !important;
  /* PERFORMANCE: Containment for grid */
  contain: layout style !important;
}

.ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider {
  display: flex !important;
  overflow-x: auto !important;
  scroll-behavior: smooth !important;
  scrollbar-width: none !important;
  -ms-overflow-style: none !important;
  cursor: grab !important;
  user-select: none !important;
  /* PERFORMANCE: GPU acceleration for scrolling */
  will-change: scroll-position !important;
  -webkit-overflow-scrolling: touch !important;
}
.ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider:active { 
  cursor: grabbing !important; 
}
.ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider::-webkit-scrollbar { 
  display: none !important; 
}

.ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-grid {
  grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr) !important;
}

.ai-collection-slideshow__product-card-{{ ai_gen_id }} {
  background-color: {{ block.settings.card_background_color }} !important;
  border-radius: {{ block.settings.card_border_radius }}px !important;
  padding: {{ block.settings.card_padding }}px !important;
  border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }} !important;
  transition: transform 0.3s ease, box-shadow 0.3s ease !important;
  display: flex !important;
  flex-direction: column !important;
  /* PERFORMANCE: Containment for cards */
  contain: layout style paint !important;
  /* PERFORMANCE: GPU acceleration for hover */
  will-change: transform !important;
}

.ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider .ai-collection-slideshow__product-card-{{ ai_gen_id }} {
  flex: 0 0 calc((100% - ({{ block.settings.products_per_row | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row }}) !important;
  max-width: calc((100% - ({{ block.settings.products_per_row | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row }}) !important;
}

.ai-collection-slideshow__product-card-{{ ai_gen_id }}:hover {
  transform: translateY(-5px) !important;
  box-shadow: 0 8px 16px rgba(0,0,0,0.1) !important;
}

.ai-collection-slideshow__product-image-wrapper-{{ ai_gen_id }} {
  position: relative !important;
  width: 100% !important;
  padding-bottom: 100% !important;
  overflow: hidden !important;
  border-radius: {{ block.settings.image_border_radius }}px !important;
  margin-bottom: 12px !important;
  background-color: #f5f5f5 !important;
  /* FIX: Reserve space to prevent CLS */
  min-height: 200px !important;
}

.ai-collection-slideshow__product-image-{{ ai_gen_id }} {
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  /* PERFORMANCE: Optimize image rendering */
  image-rendering: -webkit-optimize-contrast !important;
}

.ai-collection-slideshow__product-content-{{ ai_gen_id }} {
  display: flex !important;
  flex-direction: column !important;
  flex-grow: 1 !important;
  text-align: {{ block.settings.card_items_alignment }} !important;
  align-items: {{ block.settings.card_items_alignment | replace: 'left', 'flex-start' | replace: 'center', 'center' | replace: 'right', 'flex-end' }} !important;
}

.ai-collection-slideshow__product-title-{{ ai_gen_id }} {
  font-size: {{ block.settings.product_title_size }}px !important;
  color: {{ block.settings.product_title_color }} !important;
  margin: 0 !important;
  text-transform: {{ block.settings.product_title_text_transform }} !important;
  font-weight: {{ block.settings.product_title_weight }} !important;
  transition: color 0.3s ease !important;
  padding-top: {{ block.settings.product_title_padding_top }}px !important;
  padding-bottom: {{ block.settings.product_title_padding_bottom }}px !important;
  line-height: 1.4 !important;
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  max-height: calc({{ block.settings.product_title_size }}px * 1.4 * 2) !important;
  word-wrap: break-word !important;
}

.ai-collection-slideshow__product-title-{{ ai_gen_id }}:hover {
  color: {{ block.settings.product_title_hover_color }} !important;
}

.ai-collection-slideshow__product-stars-{{ ai_gen_id }} {
  display: flex !important;
  gap: {{ block.settings.stars_gap }}px !important;
  padding-top: {{ block.settings.stars_padding_top }}px !important;
  padding-bottom: {{ block.settings.stars_padding_bottom }}px !important;
  align-items: center !important;
}

.ai-collection-slideshow__star-{{ ai_gen_id }} {
  width: {{ block.settings.star_size }}px !important;
  height: {{ block.settings.star_size }}px !important;
  fill: {{ block.settings.star_empty_color }} !important;
}

.ai-collection-slideshow__star-{{ ai_gen_id }}.filled {
  fill: {{ block.settings.star_color }} !important;
}

.ai-collection-slideshow__product-price-wrapper-{{ ai_gen_id }} {
  display: flex !important;
  gap: 8px !important;
  align-items: center !important;
  padding-top: {{ block.settings.product_price_padding_top }}px !important;
  padding-bottom: {{ block.settings.product_price_padding_bottom }}px !important;
  flex-wrap: wrap !important;
}

.ai-collection-slideshow__product-price-{{ ai_gen_id }} {
  font-size: {{ block.settings.price_size }}px !important;
  color: {{ block.settings.price_color }} !important;
  font-weight: {{ block.settings.price_weight }} !important;
  margin: 0 !important;
}

.ai-collection-slideshow__product-compare-price-{{ ai_gen_id }} {
  font-size: {{ block.settings.compare_price_size }}px !important;
  color: {{ block.settings.compare_price_color }} !important;
  font-weight: {{ block.settings.compare_price_weight }} !important;
  text-decoration: line-through !important;
  margin: 0 !important;
}

.ai-collection-slideshow__product-button-{{ ai_gen_id }} {
  background-color: {{ block.settings.button_background_color }} !important;
  color: {{ block.settings.button_text_color }} !important;
  font-size: {{ block.settings.button_text_size }}px !important;
  font-weight: {{ block.settings.button_text_weight }} !important;
  text-transform: {{ block.settings.button_text_transform }} !important;
  letter-spacing: {{ block.settings.button_letter_spacing }}px !important;
  padding: {{ block.settings.button_padding_top }}px {{ block.settings.button_padding_sides }}px {{ block.settings.button_padding_bottom }}px !important;
  border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }} !important;
  border-radius: {{ block.settings.button_border_radius }}px !important;
  cursor: pointer !important;
  transition: all 0.3s ease !important;
  text-decoration: none !important;
  display: inline-block !important;
  margin-top: auto !important;
  width: 100% !important;
  text-align: center !important;
  /* PERFORMANCE: GPU acceleration */
  will-change: transform, background-color !important;
}

.ai-collection-slideshow__product-button-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.button_hover_background_color }} !important;
  color: {{ block.settings.button_hover_text_color }} !important;
  border-color: {{ block.settings.button_hover_border_color }} !important;
  transform: translateY(-2px) !important;
}

.ai-collection-slideshow__arrow-{{ ai_gen_id }} {
  position: absolute !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: {{ block.settings.arrow_size }}px !important;
  height: {{ block.settings.arrow_size }}px !important;
  background-color: {{ block.settings.arrow_background_color }} !important;
  border: {{ block.settings.arrow_border_width }}px solid {{ block.settings.arrow_border_color }} !important;
  border-radius: {{ block.settings.arrow_border_radius }}px !important;
  cursor: pointer !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  z-index: 10 !important;
  transition: all 0.3s ease !important;
  /* PERFORMANCE: GPU acceleration */
  will-change: transform, background-color !important;
}

.ai-collection-slideshow__arrow-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.arrow_hover_background_color }} !important;
  border-color: {{ block.settings.arrow_hover_border_color }} !important;
}

.ai-collection-slideshow__arrow-{{ ai_gen_id }}.left {
  left: {{ block.settings.arrow_position }}px !important;
}

.ai-collection-slideshow__arrow-{{ ai_gen_id }}.right {
  right: {{ block.settings.arrow_position }}px !important;
}

.ai-collection-slideshow__arrow-icon-{{ ai_gen_id }} {
  width: 60% !important;
  height: 60% !important;
  fill: {{ block.settings.arrow_color }} !important;
  transition: fill 0.3s ease !important;
}

.ai-collection-slideshow__arrow-{{ ai_gen_id }}:hover .ai-collection-slideshow__arrow-icon-{{ ai_gen_id }} {
  fill: {{ block.settings.arrow_hover_color }} !important;
}

.ai-collection-slideshow__view-all-wrapper-{{ ai_gen_id }} {
  text-align: {{ block.settings.view_all_alignment }} !important;
  margin-top: 30px !important;
}

.ai-collection-slideshow__view-all-button-{{ ai_gen_id }} {
  background-color: {{ block.settings.view_all_background_color }} !important;
  color: {{ block.settings.view_all_text_color }} !important;
  font-size: {{ block.settings.view_all_text_size }}px !important;
  font-weight: {{ block.settings.view_all_text_weight }}px !important;
  text-transform: {{ block.settings.view_all_text_transform }} !important;
  letter-spacing: {{ block.settings.view_all_letter_spacing }}px !important;
  padding: {{ block.settings.view_all_padding_vertical }}px {{ block.settings.view_all_padding_horizontal }}px !important;
  border: {{ block.settings.view_all_border_width }}px solid {{ block.settings.view_all_border_color }} !important;
  border-radius: {{ block.settings.view_all_border_radius }}px !important;
  cursor: pointer !important;
  transition: all 0.3s ease !important;
  text-decoration: none !important;
  display: inline-block !important;
}

.ai-collection-slideshow__view-all-button-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.view_all_hover_background_color }} !important;
  color: {{ block.settings.view_all_hover_text_color }} !important;
  border-color: {{ block.settings.view_all_hover_border_color }} !important;
}

/* Responsive */
@media (max-width: 768px) {
  .ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider .ai-collection-slideshow__product-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_mobile | default: 2 | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row_mobile | default: 2 }}) !important;
    max-width: calc((100% - ({{ block.settings.products_per_row_mobile | default: 2 | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row_mobile | default: 2 }}) !important;
  }
  .ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-grid {
    grid-template-columns: repeat({{ block.settings.products_per_row_mobile | default: 2 }}, 1fr) !important;
  }

  .ai-collection-slideshow-{{ ai_gen_id }} .ai-collection-slideshow__product-content-{{ ai_gen_id }}{
    text-align: center !important;
    align-items: center !important;
  }
  .ai-collection-slideshow-{{ ai_gen_id }} .ai-collection-slideshow__product-stars-{{ ai_gen_id }}{
    justify-content: center !important;
  }
  .ai-collection-slideshow-{{ ai_gen_id }} .ai-collection-slideshow__product-price-wrapper-{{ ai_gen_id }}{
    justify-content: center !important;
  }
  .ai-collection-slideshow-{{ ai_gen_id }} .ai-collection-slideshow__product-button-{{ ai_gen_id }}{
    width: 100% !important;
    align-self: stretch !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
}

@media (max-width: 480px) {
  .ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-slider .ai-collection-slideshow__product-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_mobile | default: 2 | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row_mobile | default: 2 }}) !important;
    max-width: calc((100% - ({{ block.settings.products_per_row_mobile | default: 2 | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row_mobile | default: 2 }}) !important;
  }
  .ai-collection-slideshow__products-grid-{{ ai_gen_id }}.layout-grid {
    grid-template-columns: repeat({{ block.settings.products_per_row_mobile | default: 2 }}, 1fr) !important;
  }
}

/* ── FIX 1: Prevent hidden instances from loading/rendering ── */
.ai-collection-slideshow-{{ ai_gen_id }} {
  content-visibility: auto;
  contain-intrinsic-size: 0 500px;
}

.ai-collection-slideshow-{{ ai_gen_id }}[style*="display: none"],
.ai-collection-slideshow-{{ ai_gen_id }}[style*="display:none"],
.ai-collection-slideshow-{{ ai_gen_id }}[hidden] {
  content-visibility: hidden !important;
}
{% endstyle %}

<div class="ai-collection-slideshow-{{ ai_gen_id }}">
  <div class="ai-collection-slideshow__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-collection-slideshow__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-collection-slideshow__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-collection-slideshow__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-collection-slideshow__products-wrapper-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% assign collection = collections[block.settings.collection] %}
        {% assign layout_class = 'layout-grid' %}
        {% if block.settings.layout == 'slider' %}
          {% assign layout_class = 'layout-slider' %}
        {% endif %}

        <div class="ai-collection-slideshow__products-grid-{{ ai_gen_id }} {{ layout_class }}" 
             data-slider="{{ block.settings.layout }}"
             data-id="{{ ai_gen_id }}">
          {% for product in collection.products limit: block.settings.products_to_show %}
            <div class="ai-collection-slideshow__product-card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-collection-slideshow__product-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  {%- comment -%} FIX 2: proper lazy loading with dimensions to prevent CLS {%- endcomment -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="ai-collection-slideshow__product-image-{{ ai_gen_id }}"
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div style="background: #f0f0f0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                    <span style="color: #999;">No image</span>
                  </div>
                {% endif %}
              </a>

              <div class="ai-collection-slideshow__product-content-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-collection-slideshow__product-title-{{ ai_gen_id }}">
                  {{ product.title }}
                </a>

                {% if block.settings.show_stars %}
                  <div class="ai-collection-slideshow__product-stars-{{ ai_gen_id }}">
                    {% assign rating = 4 %}
                    {% for i in (1..5) %}
                      <svg class="ai-collection-slideshow__star-{{ ai_gen_id }} {% if i <= rating %}filled{% endif %}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endfor %}
                  </div>
                {% endif %}

                <div class="ai-collection-slideshow__product-price-wrapper-{{ ai_gen_id }}">
                  <span class="ai-collection-slideshow__product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </span>
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-collection-slideshow__product-compare-price-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>

                <a href="{{ product.url }}" class="ai-collection-slideshow__product-button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>

        {% if block.settings.layout == 'slider' %}
          <button class="ai-collection-slideshow__arrow-{{ ai_gen_id }} left" data-direction="left" data-id="{{ ai_gen_id }}" aria-label="Previous products">
            <svg class="ai-collection-slideshow__arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
            </svg>
          </button>
          <button class="ai-collection-slideshow__arrow-{{ ai_gen_id }} right" data-direction="right" data-id="{{ ai_gen_id }}" aria-label="Next products">
            <svg class="ai-collection-slideshow__arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
            </svg>
          </button>
        {% endif %}
      {% endif %}
    </div>

    {% if block.settings.show_view_all and block.settings.collection != blank %}
      <div class="ai-collection-slideshow__view-all-wrapper-{{ ai_gen_id }}">
        {% assign view_all_url = '/collections/all-products?collection=' | append: block.settings.collection %}
        <a href="{{ view_all_url }}" class="ai-collection-slideshow__view-all-button-{{ ai_gen_id }}">
          {{ block.settings.view_all_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

<script>
(function() {
  'use strict';
  
  const id = '{{ ai_gen_id }}';

  // FIX 3: Skip all JS if this instance is hidden — saves CPU + prevents invisible scroll init
  const wrapper = document.querySelector('.ai-collection-slideshow-' + id);
  if (!wrapper) return;
  const wrapperStyle = window.getComputedStyle(wrapper);
  if (wrapperStyle.display === 'none' || wrapperStyle.visibility === 'hidden' || wrapper.hidden) return;

  const slider = document.querySelector('.ai-collection-slideshow__products-grid-' + id + '.layout-slider');
  if (!slider) return;

  // PERFORMANCE: Cache DOM queries
  const leftArrow = document.querySelector('.ai-collection-slideshow__arrow-' + id + '.left');
  const rightArrow = document.querySelector('.ai-collection-slideshow__arrow-' + id + '.right');
  
  let isDown = false;
  let startX;
  let scrollLeft;
  let rafId = null;
  
  function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
      const later = () => {
        clearTimeout(timeout);
        func(...args);
      };
      clearTimeout(timeout);
      timeout = setTimeout(later, wait);
    };
  }
  
  function smoothScroll(element, target) {
    if (rafId) cancelAnimationFrame(rafId);
    const start = element.scrollLeft;
    const change = target - start;
    const duration = 300;
    let startTime = null;
    function animation(currentTime) {
      if (startTime === null) startTime = currentTime;
      const timeElapsed = currentTime - startTime;
      const progress = Math.min(timeElapsed / duration, 1);
      const easeProgress = progress < 0.5 
        ? 2 * progress * progress 
        : 1 - Math.pow(-2 * progress + 2, 2) / 2;
      element.scrollLeft = start + (change * easeProgress);
      if (timeElapsed < duration) {
        rafId = requestAnimationFrame(animation);
      } else {
        rafId = null;
      }
    }
    rafId = requestAnimationFrame(animation);
  }
  
  if (leftArrow && rightArrow) {
    const scrollAmount = slider.offsetWidth * 0.8;
    leftArrow.addEventListener('click', () => {
      smoothScroll(slider, slider.scrollLeft - scrollAmount);
    });
    rightArrow.addEventListener('click', () => {
      smoothScroll(slider, slider.scrollLeft + scrollAmount);
    });
  }
  
  slider.addEventListener('mousedown', (e) => {
    isDown = true;
    slider.style.cursor = 'grabbing';
    const rect = slider.getBoundingClientRect();
    startX = e.pageX - rect.left;
    scrollLeft = slider.scrollLeft;
    if (rafId) cancelAnimationFrame(rafId);
  }, { passive: true });
  
  slider.addEventListener('mouseleave', () => {
    isDown = false;
    slider.style.cursor = 'grab';
  }, { passive: true });
  
  slider.addEventListener('mouseup', () => {
    isDown = false;
    slider.style.cursor = 'grab';
  }, { passive: true });
  
  slider.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const rect = slider.getBoundingClientRect();
    const x = e.pageX - rect.left;
    const walk = (x - startX) * 2;
    slider.scrollLeft = scrollLeft - walk;
  });
  
  let touchStartX = 0;
  let touchScrollLeft = 0;
  
  slider.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].pageX;
    touchScrollLeft = slider.scrollLeft;
    if (rafId) cancelAnimationFrame(rafId);
  }, { passive: true });
  
  slider.addEventListener('touchmove', (e) => {
    const touchX = e.touches[0].pageX;
    const walk = (touchStartX - touchX) * 1.5;
    slider.scrollLeft = touchScrollLeft + walk;
  }, { passive: true });
  
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: '50px' });
    observer.observe(slider);
  }
  
})();
</script>

