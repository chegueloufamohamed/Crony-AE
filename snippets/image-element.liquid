{% comment %}
  OPTIMIZED IMAGE ELEMENT
  Reduced from 16 sizes to 5 strategic sizes for better performance
  
  @param alt {String} - The image alt text
  @param lazyload {Boolean} - If true, lazyloads image
  @param progressive {Boolean} - If true, image is progressive
  @param stretch_width {Boolean} - If true, remove max-width
  @param additional_classes {String} - Additional CSS classes
  @param inline_style {String} - Inline CSS styles
  @param back_to_basics {Boolean} - Use standard image tag
  @param focal_point {String} - Focal point from Shopify admin
  @param object_fit {Boolean} - Resize image to fit container
  @param max_height {Number} - Max height of image
  @param loading {String} - 'eager' or 'lazy' (default: lazy)
  @param fetchpriority {String} - 'high', 'low', or 'auto'
  @param decoding {String} - 'async', 'sync', or 'auto'
  @param sizes {String} - Responsive sizes attribute
{% endcomment %}

{% liquid
  assign alt = alt | escape
  assign inline_style = inline_style | default: blank
  assign focal_point = focal_point | default: blank
  assign lazyload = lazyload
  assign loading_attr = loading | default: 'lazy'
  assign fetchpriority_attr = fetchpriority | default: 'auto'
  assign decoding_attr = decoding | default: 'async'
  assign sizes_attr = sizes | default: 'auto'

  if lazyload == nil
    assign lazyload = true
  endif
  
  comment
    Override lazyload if loading is explicitly set to eager
  endcomment
  if loading_attr == 'eager'
    assign lazyload = false
  endif
%}

{% if focal_point != blank %}
  {%- capture focal_point_style -%}
    object-fit:cover;object-position:{{ focal_point }};
  {%- endcapture -%}

  {% if inline_style != blank %}
    {% assign inline_style = inline_style | append: focal_point_style %}
  {% else %}
    {% assign inline_style = focal_point_style %}
  {% endif %}
{% endif %}

{% comment %}
  OPTIMIZED SRCSET - Only 5 strategic sizes instead of 16
  Covers: Mobile (400px), Tablet (800px), Desktop (1200px), Large (1800px), XL (2400px)
{% endcomment %}
{% if progressive %}
  {%- capture srcset -%}
    {{ image | image_url: width: 400, format: 'pjpg' }} 400w,
    {{ image | image_url: width: 800, format: 'pjpg' }} 800w,
    {{ image | image_url: width: 1200, format: 'pjpg' }} 1200w,
    {{ image | image_url: width: 1800, format: 'pjpg' }} 1800w,
    {{ image | image_url: width: 2400, format: 'pjpg' }} 2400w
  {%- endcapture -%}
{% else %}
  {%- capture srcset -%}
    {{ image | image_url: width: 400 }} 400w,
    {{ image | image_url: width: 800 }} 800w,
    {{ image | image_url: width: 1200 }} 1200w,
    {{ image | image_url: width: 1800 }} 1800w,
    {{ image | image_url: width: 2400 }} 2400w
  {%- endcapture -%}
{% endif %}

{% comment %}Loading style{% endcomment %}
{% if settings.image_loading_style == 'blur-up' %}
  {% assign low_quality_image = image | image_url: width: 50 %}
{% elsif settings.image_loading_style == 'color' %}
  {% assign dominant_color_image = image | image_url: width: 1 %}
  {% capture background_color %}
    background: url({{ dominant_color_image }});
  {% endcapture %}
{% endif %}

{% if object_fit == true %}
  {% capture crop_to_aspect_ratio %}
    max-height: {{ max_height }}px; width: calc({{ image.width }} /  {{ image.height }} * {{ max_height }}px);
  {% endcapture %}
{% endif %}

{% if back_to_basics %}
  <div
    class="image-element__wrap"
    style="{{ background_color }}{{ crop_to_aspect_ratio }};"
  >
    <img
      {% if additional_classes %}
        class="{{ additional_classes }}"
      {% endif %}
      src="{{ image | image_url: width: 600 }}"
      alt="{{ alt }}"
      style="{{ inline_style }}"
      loading="{{ loading_attr }}"
      {% if fetchpriority_attr != 'auto' %}fetchpriority="{{ fetchpriority_attr }}"{% endif %}
      decoding="{{ decoding_attr }}"
      width="{{ image.width }}"
      height="{{ image.height }}"
    >
  </div>
{% else %}
  <div
    class="image-element__wrap"
    style="
      {{ background_color }}
      {{ crop_to_aspect_ratio }}
      {% unless stretch_width == true or object_fit %}
        max-width: {{ image.width }}px;
      {% endunless %}
    "
  >
    {%- if image == nil or lazyload -%}
      <img
        class="
          lazyload
          transition--{{ settings.image_loading_style }}
          {{ additional_classes }}
        "
        alt="{{ alt }}"
        {% if low_quality_image %}
          src="{{ low_quality_image }}"
        {% endif %}
        data-src="{{ image | image_url: width: 600 }}"
        data-sizes="{{ sizes_attr }}"
        data-aspectratio="{{ image.width }}/{{ image.height }}"
        data-srcset="{{ srcset }}"
        style="{{ inline_style }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        srcset="data:image/svg+xml;utf8,<svg%20xmlns='http://www.w3.org/2000/svg'%20width='{{ image.width }}'%20height='{{ image.height }}'></svg>"
        loading="{{ loading_attr }}"
        {% if fetchpriority_attr != 'auto' %}fetchpriority="{{ fetchpriority_attr }}"{% endif %}
        decoding="{{ decoding_attr }}"
      >
    {%- else -%}
      <img
        src="{{ image | image_url: width: 600 }}"
        srcset="{{ srcset }}"
        sizes="{{ sizes_attr }}"
        alt="{{ alt }}"
        class="{{ additional_classes }}"
        style="{{ inline_style }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="{{ loading_attr }}"
        {% if fetchpriority_attr != 'auto' %}fetchpriority="{{ fetchpriority_attr }}"{% endif %}
        decoding="{{ decoding_attr }}"
      >
    {%- endif -%}
  </div>
{% endif %}

{% comment %}Fallback for no javascript{% endcomment %}
<noscript>
  <img
    class="
      noscript
      {{ additional_classes }}
    "
    src="{{ image | image_url: width: 600 }}"
    alt="{{ alt | escape }}"
    style="{{ inline_style }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
  >
</noscript>