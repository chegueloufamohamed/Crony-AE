<script>
window.addEventListener("load", function () {
  setTimeout(function () {
    var scripts = [
      // GTM + GA
      "https://www.googletagmanager.com/gtag/js?id=GTM-PK9MXVS4",
      "https://www.googletagmanager.com/gtag/js?id=GT-5MCCQGQZ",

      // FB Pixel
      "https://connect.facebook.net/en_US/fbevents.js",

      // Microsoft Clarity (if used)
      "https://www.clarity.ms/tag/YOUR_CLARITY_ID"
    ];

    scripts.forEach(function(src){
      var s = document.createElement("script");
      s.src = src;
      s.async = true;
      document.body.appendChild(s);
    });

  }, 3000); // delay 3 seconds
});
</script>
