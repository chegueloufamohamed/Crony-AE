    "image-text-1": {
      "type": "image-text",
      "blocks": {
        "block-2": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Talkie_Walkie.webp",
            "title": "Baofeng 8W UV-5R 5-8 KM Portable Dual-frequency ",
            "text": "<p><strong>Dual-Frequency Power, Anywhere You Go</strong><br/><br/>Stay connected up to <strong>8 KM</strong> away with crystal-clear communication and unmatched durability. The UV-5R offers <strong>dual-band UHF/VHF performance</strong>, long-lasting <strong>4000 mAh battery</strong>, and a <strong>bright LCD display</strong> for easy use day or night. Perfect for professionals, outdoor adventurers, and security teams who demand reliability on every channel.</p>",
            "button_label": "View",
            "link": "shopify://products/baofeng-8w-bf-uv-5r-walkie-talkies-5-16km-portable-dual-frequency-walkie-talkies-1-pcs",
            "text_color": "#1d1d1d",
            "bg_color": "#ffffff",
            "bg_color_gradient": ""
          }
        },
        "block-1": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/V7.jpg",
            "title": "CRONY V7 Electric Scooter",
            "text": "<p>The <strong>CRONY X7</strong> is the ultimate <strong>beast of performance</strong> engineered for riders who demand power without limits.<br/><br/>Equipped with <strong>dual 5000 W motors</strong> and a <strong>72 V 50 Ah battery</strong>, it delivers breathtaking acceleration and a range of up to <strong>190 km</strong> on a single charge.<br/><br/>Its <strong>14-inch off-road tires</strong>, <strong>hydraulic suspension</strong>, and <strong>four-LED headlamps</strong> keep you in control on any terrain.<br/><br/>Designed with a <strong>big LCD display</strong>, <strong>oil brakes</strong>, and <strong>IP60 water resistance</strong>, the X7 combines strength, intelligence, and style in one unstoppable ride.</p><p><strong>CRONY X7 — Power Meets Precision.</strong></p>",
            "button_label": "View",
            "link": "shopify://products/crony-x7-14-inch-off-road-wide-tire-high-configuration-dual-motor-e-scooter",
            "text_color": "#1b1f23",
            "bg_color": "#ffffff",
            "bg_color_gradient": ""
          }
        }
      },
