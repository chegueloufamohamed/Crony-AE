    "custom_html_gAc4Wi": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "custom_html": "<body>\n\n\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SOP – Order Management & Issue Tracking</title>\n<link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@400;600;800&display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg: #0d0f14;\n    --surface: #141820;\n    --surface2: #1c2130;\n    --border: #252d3d;\n    --accent: #f5a623;\n    --accent2: #e8572a;\n    --text: #e2e8f0;\n    --muted: #7a8ba8;\n    --success: #2dd4a0;\n    --danger: #f25c5c;\n    --tag-bg: #1e2a1a;\n    --tag-color: #6ee7a0;\n  }\n\n  body {\n    background: var(--bg);\n    color: var(--text);\n    font-family: 'Syne', sans-serif;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* ── HEADER ── */\n  header {\n    background: var(--surface);\n    border-bottom: 1px solid var(--border);\n    padding: 0 32px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    height: 64px;\n    position: sticky;\n    top: 0;\n    z-index: 100;\n  }\n  .logo {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .logo-dot {\n    width: 10px; height: 10px;\n    border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 10px var(--accent);\n  }\n  .logo-text {\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--muted);\n  }\n  .logo-text span { color: var(--text); }\n  .header-badge {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    color: var(--accent);\n    background: rgba(245,166,35,0.1);\n    border: 1px solid rgba(245,166,35,0.25);\n    padding: 4px 10px;\n    border-radius: 4px;\n    letter-spacing: 0.05em;\n  }\n\n  /* ── LAYOUT ── */\n  .layout {\n    display: flex;\n    flex: 1;\n    min-height: calc(100vh - 64px);\n  }\n\n  /* ── SIDEBAR ── */\n  aside {\n    width: 240px;\n    background: var(--surface);\n    border-right: 1px solid var(--border);\n    padding: 24px 0;\n    flex-shrink: 0;\n    display: flex;\n    flex-direction: column;\n  }\n  .nav-label {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 10px;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: var(--muted);\n    padding: 0 20px 10px;\n    margin-top: 8px;\n  }\n  .nav-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 11px 20px;\n    cursor: pointer;\n    font-size: 14px;\n    font-weight: 600;\n    color: var(--muted);\n    border-left: 3px solid transparent;\n    transition: all 0.18s ease;\n    user-select: none;\n  }\n  .nav-item:hover { color: var(--text); background: rgba(255,255,255,0.03); }\n  .nav-item.active {\n    color: var(--accent);\n    border-left-color: var(--accent);\n    background: rgba(245,166,35,0.07);\n  }\n  .nav-icon {\n    font-size: 16px;\n    width: 20px;\n    text-align: center;\n    flex-shrink: 0;\n  }\n  .nav-divider {\n    height: 1px;\n    background: var(--border);\n    margin: 12px 20px;\n  }\n\n  /* ── MAIN CONTENT ── */\n  main {\n    flex: 1;\n    padding: 40px 48px;\n    overflow-y: auto;\n    max-width: 900px;\n  }\n\n  .section { display: none; animation: fadeIn 0.25s ease; }\n  .section.active { display: block; }\n\n  @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(8px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n\n  .page-title {\n    font-size: 28px;\n    font-weight: 800;\n    color: var(--text);\n    margin-bottom: 6px;\n    line-height: 1.2;\n  }\n  .page-sub {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 12px;\n    color: var(--muted);\n    margin-bottom: 36px;\n    letter-spacing: 0.05em;\n  }\n\n  /* ── CARDS ── */\n  .card {\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 10px;\n    padding: 24px 28px;\n    margin-bottom: 20px;\n  }\n  .card-title {\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: var(--accent);\n    margin-bottom: 16px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .card-title::after {\n    content: '';\n    flex: 1;\n    height: 1px;\n    background: var(--border);\n  }\n\n  /* ── WORKFLOW STEPS ── */\n  .steps { display: flex; flex-direction: column; gap: 0; }\n  .step {\n    display: flex;\n    gap: 16px;\n    padding: 16px 0;\n    border-bottom: 1px solid var(--border);\n    position: relative;\n  }\n  .step:last-child { border-bottom: none; }\n  .step-num {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    color: var(--accent);\n    background: rgba(245,166,35,0.1);\n    border: 1px solid rgba(245,166,35,0.2);\n    border-radius: 6px;\n    width: 28px;\n    height: 28px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    font-weight: 600;\n  }\n  .step-body { flex: 1; }\n  .step-name {\n    font-size: 14px;\n    font-weight: 600;\n    color: var(--text);\n    margin-bottom: 4px;\n  }\n  .step-desc {\n    font-size: 13px;\n    color: var(--muted);\n    line-height: 1.6;\n  }\n\n  /* ── RULE CARDS ── */\n  .rule-row {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin-bottom: 20px;\n  }\n  @media (max-width: 680px) { .rule-row { grid-template-columns: 1fr; } }\n\n  /* ── ORDER PROCESS TABLE ── */\n  .order-scenario {\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    overflow: hidden;\n    margin-bottom: 16px;\n  }\n  .scenario-header {\n    background: var(--surface);\n    padding: 12px 18px;\n    font-size: 13px;\n    font-weight: 600;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .scenario-body {\n    padding: 14px 18px;\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .action-line {\n    font-size: 13px;\n    color: var(--muted);\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .action-line::before {\n    content: '→';\n    color: var(--accent);\n    font-weight: 700;\n  }\n  .badge {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    padding: 2px 8px;\n    border-radius: 4px;\n    font-weight: 600;\n  }\n  .badge-cancel { background: rgba(242,92,92,0.15); color: var(--danger); }\n  .badge-ship   { background: rgba(45,212,160,0.15); color: var(--success); }\n  .badge-tag    { background: rgba(245,166,35,0.12); color: var(--accent); }\n  .badge-warn   { background: rgba(232,87,42,0.15); color: var(--accent2); }\n\n  /* ── TAGS & NOTES ── */\n  .tags-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-bottom: 20px;\n  }\n  @media (max-width: 600px) { .tags-grid { grid-template-columns: 1fr; } }\n  .tag-card {\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 16px 18px;\n  }\n  .tag-name {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 13px;\n    font-weight: 600;\n    color: var(--tag-color);\n    background: var(--tag-bg);\n    display: inline-block;\n    padding: 3px 10px;\n    border-radius: 4px;\n    margin-bottom: 10px;\n  }\n  .tag-when {\n    font-size: 12px;\n    color: var(--muted);\n    margin-bottom: 6px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n  }\n  .tag-scenarios { display: flex; flex-direction: column; gap: 4px; }\n  .tag-scenario {\n    font-size: 12px;\n    color: var(--text);\n    padding-left: 12px;\n    position: relative;\n    line-height: 1.5;\n  }\n  .tag-scenario::before {\n    content: '·';\n    position: absolute;\n    left: 2px;\n    color: var(--accent);\n  }\n  .note-box {\n    background: var(--surface2);\n    border-left: 3px solid var(--accent);\n    border-radius: 0 8px 8px 0;\n    padding: 14px 18px;\n    margin-bottom: 10px;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  .note-label {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 10px;\n    color: var(--accent);\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    margin-bottom: 2px;\n  }\n  .note-context { font-size: 12px; color: var(--muted); }\n  .note-text    { font-size: 13px; color: var(--text); font-style: italic; }\n\n  /* ── DAILY WORKFLOW ── */\n  .flow-list { display: flex; flex-direction: column; gap: 0; }\n  .flow-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 14px;\n    padding: 14px 0;\n    border-bottom: 1px solid var(--border);\n  }\n  .flow-item:last-child { border-bottom: none; }\n  .flow-num {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 12px;\n    color: var(--bg);\n    background: var(--accent);\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    flex-shrink: 0;\n    margin-top: 1px;\n  }\n  .flow-text { font-size: 14px; color: var(--text); line-height: 1.5; }\n  .flow-sub  { font-size: 12px; color: var(--muted); margin-top: 2px; }\n\n  /* ── RULES ── */\n  .rule-item {\n    display: flex;\n    gap: 14px;\n    align-items: flex-start;\n    padding: 12px 0;\n    border-bottom: 1px solid var(--border);\n  }\n  .rule-item:last-child { border-bottom: none; }\n  .rule-icon { font-size: 18px; flex-shrink: 0; }\n  .rule-text { font-size: 14px; color: var(--text); line-height: 1.5; }\n  .rule-note { font-size: 12px; color: var(--muted); margin-top: 2px; }\n\n  /* ── RETURNS ── */\n  .return-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n  }\n  .return-table th {\n    text-align: left;\n    padding: 10px 14px;\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: var(--muted);\n    border-bottom: 1px solid var(--border);\n  }\n  .return-table td {\n    padding: 12px 14px;\n    border-bottom: 1px solid rgba(37,45,61,0.6);\n    vertical-align: top;\n  }\n  .return-table tr:last-child td { border-bottom: none; }\n  .return-table tr:hover td { background: rgba(255,255,255,0.02); }\n\n  /* ── END OF DAY CHECKLIST ── */\n  .checklist { display: flex; flex-direction: column; gap: 10px; }\n  .check-item {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 13px 16px;\n    cursor: pointer;\n    transition: border-color 0.15s;\n  }\n  .check-item:hover { border-color: rgba(245,166,35,0.3); }\n  .check-item.checked { border-color: var(--success); background: rgba(45,212,160,0.05); }\n  .check-box {\n    width: 18px; height: 18px;\n    border: 2px solid var(--border);\n    border-radius: 4px;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 12px;\n    transition: all 0.15s;\n  }\n  .check-item.checked .check-box {\n    background: var(--success);\n    border-color: var(--success);\n    color: #0d0f14;\n  }\n  .check-label { font-size: 14px; color: var(--text); }\n  .check-item.checked .check-label { color: var(--muted); text-decoration: line-through; }\n  .reset-btn {\n    margin-top: 16px;\n    background: none;\n    border: 1px solid var(--border);\n    color: var(--muted);\n    padding: 8px 18px;\n    border-radius: 6px;\n    cursor: pointer;\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 12px;\n    transition: all 0.15s;\n  }\n  .reset-btn:hover { border-color: var(--accent); color: var(--accent); }\n\n  /* ── INFO ALERT ── */\n  .alert {\n    border-radius: 8px;\n    padding: 14px 18px;\n    margin-bottom: 20px;\n    font-size: 13px;\n    line-height: 1.6;\n    display: flex;\n    gap: 12px;\n    align-items: flex-start;\n  }\n  .alert-warn {\n    background: rgba(245,166,35,0.08);\n    border: 1px solid rgba(245,166,35,0.2);\n    color: var(--text);\n  }\n  .alert-icon { font-size: 16px; flex-shrink: 0; }\n\n  /* ── FOOTER ── */\n  footer {\n    border-top: 1px solid var(--border);\n    padding: 14px 48px;\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    color: var(--muted);\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n</style>\n\n\n\n<header>\n  <div class=\"logo\">\n    <div class=\"logo-dot\"></div>\n    <div class=\"logo-text\">\n<span>NAEL</span> · Order Management SOP</div>\n  </div>\n  <div class=\"header-badge\">v2.0 LIVE</div>\n</header>\n\n<div class=\"layout\">\n  <!-- SIDEBAR -->\n  <aside>\n    <div class=\"nav-label\">Overview</div>\n    <div class=\"nav-item active\" onclick=\"show('workflow')\">\n      <span class=\"nav-icon\">⚡</span> Daily Workflow\n    </div>\n    <div class=\"nav-divider\"></div>\n    <div class=\"nav-label\">Order Steps</div>\n    <div class=\"nav-item\" onclick=\"show('open-orders')\">\n      <span class=\"nav-icon\">📋</span> Open Orders\n    </div>\n    <div class=\"nav-item\" onclick=\"show('process')\">\n      <span class=\"nav-icon\">⚙️</span> Process Orders\n    </div>\n    <div class=\"nav-item\" onclick=\"show('shipping')\">\n      <span class=\"nav-icon\">📦</span> After Shipping\n    </div>\n    <div class=\"nav-item\" onclick=\"show('followup')\">\n      <span class=\"nav-icon\">🔍</span> Follow Up\n    </div>\n    <div class=\"nav-item\" onclick=\"show('returns')\">\n      <span class=\"nav-icon\">↩️</span> Returns\n    </div>\n    <div class=\"nav-divider\"></div>\n    <div class=\"nav-label\">Reference</div>\n    <div class=\"nav-item\" onclick=\"show('tags-notes')\">\n      <span class=\"nav-icon\">🏷️</span> Tags & Notes\n    </div>\n    <div class=\"nav-item\" onclick=\"show('rules')\">\n      <span class=\"nav-icon\">📌</span> Rules\n    </div>\n    <div class=\"nav-item\" onclick=\"show('eod')\">\n      <span class=\"nav-icon\">✅</span> End of Day\n    </div>\n  </aside>\n\n  <!-- MAIN -->\n  <main>\n\n    <!-- ══ DAILY WORKFLOW ══ -->\n    <div id=\"workflow\" class=\"section active\">\n      <div class=\"page-title\">Daily Workflow</div>\n      <div class=\"page-sub\">COMPLETE THESE STEPS IN ORDER — EVERY DAY</div>\n\n      <div class=\"alert alert-warn\">\n        <span class=\"alert-icon\">⚠️</span>\n        <span><strong>Daily Rule:</strong> There must be no old unfulfilled orders. Every order must end as Fulfilled, Cancelled, Returned, or Archived before end of day.</span>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Daily Execution Sequence</div>\n        <div class=\"flow-list\">\n          <div class=\"flow-item\">\n<div class=\"flow-num\">1</div>\n<div>\n<div class=\"flow-text\">Check unfulfilled orders</div>\n<div class=\"flow-sub\">Shopify → Orders → Open + Unfulfilled</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">2</div>\n<div>\n<div class=\"flow-text\">Process all orders</div>\n<div class=\"flow-sub\">Paid orders ship directly · COD orders require a call</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">3</div>\n<div>\n<div class=\"flow-text\">Ship / prepare pickup and mark Fulfilled</div>\n<div class=\"flow-sub\">Add note after every status change</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">4</div>\n<div>\n<div class=\"flow-text\">Check delivery platform and update status</div>\n<div class=\"flow-sub\">Verify order status, progress, and customer response</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">5</div>\n<div>\n<div class=\"flow-text\">Cancel when needed — always with tag + note</div>\n<div class=\"flow-sub\">No exceptions: every cancellation needs a reason</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">6</div>\n<div>\n<div class=\"flow-text\">Follow up fulfilled orders from ALL previous days</div>\n<div class=\"flow-sub\">Shopify → Fulfilled + Open</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">7</div>\n<div>\n<div class=\"flow-text\">Handle returns</div>\n<div class=\"flow-sub\">Close return, add tag and note</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">8</div>\n<div>\n<div class=\"flow-text\">Archive delivered orders</div>\n<div class=\"flow-sub\">Delivered + no action needed = Archive</div>\n</div>\n</div>\n          <div class=\"flow-item\">\n<div class=\"flow-num\">9</div>\n<div>\n<div class=\"flow-text\">End day with no pending orders</div>\n<div class=\"flow-sub\">Open + Unfulfilled filter must be empty</div>\n</div>\n</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ OPEN ORDERS ══ -->\n    <div id=\"open-orders\" class=\"section\">\n      <div class=\"page-title\">Open Orders</div>\n      <div class=\"page-sub\">STEP 1 — FILTER AND IDENTIFY</div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Shopify Filter</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n            <div class=\"step-num\">1</div>\n            <div class=\"step-body\">\n              <div class=\"step-name\">Go to Shopify → Orders</div>\n              <div class=\"step-desc\">Navigate to the main Orders section in your Shopify admin.</div>\n            </div>\n          </div>\n          <div class=\"step\">\n            <div class=\"step-num\">2</div>\n            <div class=\"step-body\">\n              <div class=\"step-name\">Apply Filters</div>\n              <div class=\"step-desc\">\n                Order status = <span class=\"badge badge-warn\">Open</span>  \n                Fulfillment status = <span class=\"badge badge-cancel\">Unfulfilled</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"step\">\n            <div class=\"step-num\">3</div>\n            <div class=\"step-body\">\n              <div class=\"step-name\">Process Immediately</div>\n              <div class=\"step-desc\">Every order showing in this filter must be actioned before end of day. No exceptions.</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Valid End States</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n<div class=\"step-num\">✓</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Fulfilled</div>\n<div class=\"step-desc\">Shipped or handed to courier</div>\n</div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">✓</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Cancelled</div>\n<div class=\"step-desc\">With note and tag attached</div>\n</div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">✓</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Returned</div>\n<div class=\"step-desc\">Return closed and documented</div>\n</div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">✓</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Archived</div>\n<div class=\"step-desc\">Delivered and no further action needed</div>\n</div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">✓</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Followed Up</div>\n<div class=\"step-desc\">Fulfilled and actively monitored</div>\n</div>\n</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ PROCESS ORDERS ══ -->\n    <div id=\"process\" class=\"section\">\n      <div class=\"page-title\">Process Orders</div>\n      <div class=\"page-sub\">STEP 2 — ACT ON EVERY ORDER TYPE</div>\n\n      <div class=\"order-scenario\">\n        <div class=\"scenario-header\" style=\"border-left: 3px solid var(--success);\">\n          <span>💳</span> Paid Orders\n        </div>\n        <div class=\"scenario-body\">\n          <div class=\"action-line\">Ship directly</div>\n          <div class=\"action-line\">Mark as <span class=\"badge badge-ship\">Fulfilled</span>\n</div>\n          <div class=\"action-line\">Note: <em>\"Order shipped\"</em>\n</div>\n        </div>\n      </div>\n\n      <div class=\"order-scenario\">\n        <div class=\"scenario-header\" style=\"border-left: 3px solid var(--accent);\">\n          <span>📞</span> COD Orders — Call the Customer First\n        </div>\n        <div class=\"scenario-body\">\n          <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:4px;\">\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--success);margin-bottom:8px;\">✅ Customer Confirms</div>\n              <div class=\"action-line\">Ship order</div>\n              <div class=\"action-line\">Mark <span class=\"badge badge-ship\">Fulfilled</span>\n</div>\n              <div class=\"action-line\">Note: <em>\"Customer confirmed – shipped\"</em>\n</div>\n            </div>\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">❌ No Answer</div>\n              <div class=\"action-line\">Cancel order</div>\n              <div class=\"action-line\"><span class=\"badge badge-tag\">no_answer</span></div>\n              <div class=\"action-line\">Note: <em>\"Customer not answering\"</em>\n</div>\n            </div>\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">📵 Wrong Number</div>\n              <div class=\"action-line\">Cancel order</div>\n              <div class=\"action-line\"><span class=\"badge badge-tag\">wrong_number</span></div>\n              <div class=\"action-line\">Note: <em>\"Wrong / invalid number\"</em>\n</div>\n            </div>\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">🚫 Customer Cancels</div>\n              <div class=\"action-line\">Cancel order</div>\n              <div class=\"action-line\">Note: <em>\"Customer cancelled\"</em>\n</div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n\n      <div class=\"order-scenario\">\n        <div class=\"scenario-header\" style=\"border-left: 3px solid var(--danger);\">\n          <span>⚠️</span> Problem Orders\n        </div>\n        <div class=\"scenario-body\">\n          <div style=\"display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:4px;\">\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">🤖 Fake Order</div>\n              <div class=\"action-line\">Cancel</div>\n              <div class=\"action-line\"><span class=\"badge badge-tag\">fake_order</span></div>\n            </div>\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">📦 Out of Stock</div>\n              <div class=\"action-line\">Cancel</div>\n              <div class=\"action-line\"><span class=\"badge badge-tag\">product_issue</span></div>\n            </div>\n\n            <div style=\"background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;\">\n              <div style=\"font-size:12px;font-weight:600;color:var(--danger);margin-bottom:8px;\">💳 Payment Fail</div>\n              <div class=\"action-line\">Cancel</div>\n              <div class=\"action-line\"><span class=\"badge badge-tag\">payment_issue</span></div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ AFTER SHIPPING ══ -->\n    <div id=\"shipping\" class=\"section\">\n      <div class=\"page-title\">After Shipping / Pickup</div>\n      <div class=\"page-sub\">STEP 3 — MARK AND NOTE EVERY FULFILLMENT</div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Order Shipped</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n<div class=\"step-num\">1</div>\n<div class=\"step-body\"><div class=\"step-name\">Change status → <span class=\"badge badge-ship\">Fulfilled</span>\n</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">2</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Add note</div>\n<div class=\"step-desc\"><em>\"Order shipped\"</em></div>\n</div>\n</div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Order Handed to Courier / Ready for Pickup</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n<div class=\"step-num\">1</div>\n<div class=\"step-body\"><div class=\"step-name\">Mark as <span class=\"badge badge-ship\">Fulfilled</span>\n</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">2</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Add note</div>\n<div class=\"step-desc\"><em>\"Order handed to courier / ready for pickup\"</em></div>\n</div>\n</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ FOLLOW UP ══ -->\n    <div id=\"followup\" class=\"section\">\n      <div class=\"page-title\">Follow Up Fulfilled Orders</div>\n      <div class=\"page-sub\">STEP 4 — CHECK ALL PREVIOUS DAYS</div>\n\n      <div class=\"alert alert-warn\">\n        <span class=\"alert-icon\">📌</span>\n        <span>You must check <strong>ALL open fulfilled orders from ALL previous days</strong>, not just today's.</span>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Shopify Filter</div>\n        <div class=\"action-line\" style=\"margin:4px 0;\">Fulfillment status = <span class=\"badge badge-ship\">Fulfilled</span>\n</div>\n        <div class=\"action-line\" style=\"margin:4px 0;\">Order status = <span class=\"badge badge-warn\">Open</span>\n</div>\n        <div style=\"font-size:13px;color:var(--muted);margin-top:10px;\">These are shipped or picked-up orders still in process.</div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Delivery Platform Check</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n<div class=\"step-num\">→</div>\n<div class=\"step-body\"><div class=\"step-name\">Order status</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">→</div>\n<div class=\"step-body\"><div class=\"step-name\">Delivery progress</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">→</div>\n<div class=\"step-body\"><div class=\"step-name\">Customer response</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">→</div>\n<div class=\"step-body\"><div class=\"step-name\">Any delay or issue</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">!</div>\n<div class=\"step-body\"><div class=\"step-name\">Update Shopify based on this information</div></div>\n</div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">What To Do Per Status</div>\n\n        <div class=\"order-scenario\" style=\"margin-bottom:10px;\">\n          <div class=\"scenario-header\" style=\"border-left:3px solid var(--success);\">✅ Delivered</div>\n          <div class=\"scenario-body\"><div class=\"action-line\">Archive the order</div></div>\n        </div>\n\n        <div class=\"order-scenario\" style=\"margin-bottom:10px;\">\n          <div class=\"scenario-header\" style=\"border-left:3px solid var(--accent);\">⏳ Delayed</div>\n          <div class=\"scenario-body\">\n            <div class=\"action-line\">Contact courier</div>\n            <div class=\"action-line\">Note: <em>\"Delivery delayed – follow-up done\"</em>\n</div>\n          </div>\n        </div>\n\n        <div class=\"order-scenario\" style=\"margin-bottom:10px;\">\n          <div class=\"scenario-header\" style=\"border-left:3px solid var(--accent2);\">📵 Courier Cannot Reach Customer</div>\n          <div class=\"scenario-body\">\n            <div class=\"action-line\">Call customer again</div>\n            <div class=\"action-line\">Note: <em>\"Courier called, no answer – customer contacted again\"</em>\n</div>\n            <div class=\"action-line\" style=\"color:var(--danger);\">If still no answer → <span class=\"badge badge-tag\">no_answer</span>\n</div>\n          </div>\n        </div>\n\n        <div class=\"order-scenario\" style=\"margin-bottom:10px;\">\n          <div class=\"scenario-header\" style=\"border-left:3px solid var(--danger);\">🚫 Customer Refuses Delivery</div>\n          <div class=\"scenario-body\">\n            <div class=\"action-line\">Keep Fulfilled (temporary)</div>\n            <div class=\"action-line\">Tag: <span class=\"badge badge-tag\">refused_delivery</span>\n</div>\n            <div class=\"action-line\">Note: <em>\"Shipped but refused\"</em>\n</div>\n            <div class=\"action-line\" style=\"color:var(--muted);\">Once return confirmed → Cancel + Note: <em>\"Returned after refusal\"</em>\n</div>\n          </div>\n        </div>\n\n        <div class=\"order-scenario\">\n          <div class=\"scenario-header\" style=\"border-left:3px solid var(--danger);\">🔧 Courier Issue</div>\n          <div class=\"scenario-body\">\n            <div class=\"action-line\">Check delivery platform</div>\n            <div class=\"action-line\">Contact courier</div>\n            <div class=\"action-line\">If cancelled → <span class=\"badge badge-tag\">delivery_issue</span>\n</div>\n            <div class=\"action-line\">Note: <em>\"Courier issue\"</em>\n</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ RETURNS ══ -->\n    <div id=\"returns\" class=\"section\">\n      <div class=\"page-title\">Returns</div>\n      <div class=\"page-sub\">STEP 5 — CLOSE AND DOCUMENT EVERY RETURN</div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">When Return is Completed</div>\n        <div class=\"steps\">\n          <div class=\"step\">\n<div class=\"step-num\">1</div>\n<div class=\"step-body\"><div class=\"step-name\">Set Return status = Closed</div></div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">2</div>\n<div class=\"step-body\">\n<div class=\"step-name\">Add the correct tag based on reason</div>\n<div class=\"step-desc\">See table below</div>\n</div>\n</div>\n          <div class=\"step\">\n<div class=\"step-num\">3</div>\n<div class=\"step-body\"><div class=\"step-name\">Add a note explaining the reason</div></div>\n</div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Return Tag Reference</div>\n        <table class=\"return-table\">\n          <thead>\n            <tr>\n              <th>Reason</th>\n              <th>Tag</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr>\n              <td style=\"color:var(--text);\">Customer not answering</td>\n              <td><span class=\"badge badge-tag\">no_answer</span></td>\n            </tr>\n            <tr>\n              <td style=\"color:var(--text);\">Wrong number</td>\n              <td><span class=\"badge badge-tag\">wrong_number</span></td>\n            </tr>\n            <tr>\n              <td style=\"color:var(--text);\">Refused delivery</td>\n              <td><span class=\"badge badge-tag\">refused_delivery</span></td>\n            </tr>\n            <tr>\n              <td style=\"color:var(--text);\">Product issue</td>\n              <td><span class=\"badge badge-tag\">product_issue</span></td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </div>\n\n    <!-- ══ TAGS & NOTES ══ -->\n    <div id=\"tags-notes\" class=\"section\">\n      <div class=\"page-title\">Tags & Notes</div>\n      <div class=\"page-sub\">STEPS 7 & 8 — REQUIRED ON EVERY CANCELLED OR RETURNED ORDER</div>\n\n      <div class=\"alert alert-warn\">\n        <span class=\"alert-icon\">⚠️</span>\n        <span><strong>Rule:</strong> Every cancelled or returned order must have a <strong>Note</strong> (explanation) and a <strong>Tag</strong> (category). No exceptions.</span>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Tags — Cancelled Orders</div>\n        <div class=\"tags-grid\">\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">no_answer</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">COD call — customer didn't answer</div>\n              <div class=\"tag-scenario\">Courier couldn't reach customer (still no answer)</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">wrong_number</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Phone number is wrong or invalid</div>\n              <div class=\"tag-scenario\">Number not in service / unreachable</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">refused_delivery</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Customer refused to accept the shipment</div>\n              <div class=\"tag-scenario\">Used temporarily until return is confirmed</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">delivery_issue</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Problem on the courier's end</div>\n              <div class=\"tag-scenario\">Order cancelled due to courier failure</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">product_issue</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Item is out of stock</div>\n              <div class=\"tag-scenario\">Product cannot be shipped</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">payment_issue</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Payment failed or declined</div>\n            </div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">fake_order</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\">\n              <div class=\"tag-scenario\">Invalid or suspicious order details</div>\n              <div class=\"tag-scenario\">Order appears to be fraudulent</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Tags — Returned Orders</div>\n        <div class=\"tags-grid\">\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">no_answer</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\"><div class=\"tag-scenario\">Return happened because customer was unreachable</div></div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">wrong_number</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\"><div class=\"tag-scenario\">Return happened due to invalid contact info</div></div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">refused_delivery</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\"><div class=\"tag-scenario\">Customer actively refused to take the package</div></div>\n          </div>\n          <div class=\"tag-card\">\n            <div class=\"tag-name\">product_issue</div>\n            <div class=\"tag-when\">When to use</div>\n            <div class=\"tag-scenarios\"><div class=\"tag-scenario\">Item returned due to product problem</div></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Standard Notes Reference</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Order Shipped</div>\n<div class=\"note-text\">\"Order shipped\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">COD Confirmed</div>\n<div class=\"note-text\">\"Customer confirmed – shipped\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">COD No Answer</div>\n<div class=\"note-text\">\"Customer not answering\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Wrong Number</div>\n<div class=\"note-text\">\"Wrong / invalid number\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Customer Cancelled</div>\n<div class=\"note-text\">\"Customer cancelled\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Fake Order</div>\n<div class=\"note-text\">\"Fake order / invalid details\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Out of Stock</div>\n<div class=\"note-text\">\"Out of stock\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Payment Failed</div>\n<div class=\"note-text\">\"Payment failed\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Courier Pickup</div>\n<div class=\"note-text\">\"Order handed to courier / ready for pickup\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Delivery Delayed</div>\n<div class=\"note-text\">\"Delivery delayed – follow-up done\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Courier Couldn't Reach</div>\n<div class=\"note-text\">\"Courier called, no answer – customer contacted again\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Refused Delivery</div>\n<div class=\"note-text\">\"Shipped but refused\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Returned After Refusal</div>\n<div class=\"note-text\">\"Returned after refusal\"</div>\n</div>\n        <div class=\"note-box\">\n<div class=\"note-label\">Courier Issue</div>\n<div class=\"note-text\">\"Courier issue\"</div>\n</div>\n      </div>\n    </div>\n\n    <!-- ══ RULES ══ -->\n    <div id=\"rules\" class=\"section\">\n      <div class=\"page-title\">Rules</div>\n      <div class=\"page-sub\">STEP 8 & FINAL — NON-NEGOTIABLE STANDARDS</div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Core Rules</div>\n        <div class=\"steps\">\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">🏷️</div>\n<div>\n<div class=\"rule-text\">Every cancelled or returned order must have a <strong>Note</strong> and a <strong>Tag</strong>\n</div>\n<div class=\"rule-note\">Notes = explanation · Tags = category</div>\n</div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">📅</div>\n<div>\n<div class=\"rule-text\">Unfulfilled orders should only ever be from the <strong>same day</strong>\n</div>\n<div class=\"rule-note\">No order carries over unfulfilled to the next day</div>\n</div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">🔁</div>\n<div><div class=\"rule-text\">Every fulfilled order must be followed until: Delivered & archived · Cancelled · Returned</div></div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">✅</div>\n<div><div class=\"rule-text\">Every order must end as: Fulfilled · Cancelled · Returned · Archived</div></div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">📦</div>\n<div>\n<div class=\"rule-text\">Process every order the <strong>same day</strong>\n</div>\n<div class=\"rule-note\">Ship or prepare for pickup and mark fulfilled immediately</div>\n</div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">🔍</div>\n<div><div class=\"rule-text\">Check delivery platform <strong>daily</strong>\n</div></div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">❌</div>\n<div><div class=\"rule-text\">Cancel returned/refused orders <strong>only after confirmation</strong>\n</div></div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">🗂️</div>\n<div><div class=\"rule-text\">Archive when delivery is complete and no action is needed</div></div>\n</div>\n          <div class=\"rule-item\">\n<div class=\"rule-icon\">🔄</div>\n<div><div class=\"rule-text\">\n<strong>Repeat daily</strong> — no exceptions</div></div>\n</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ END OF DAY ══ -->\n    <div id=\"eod\" class=\"section\">\n      <div class=\"page-title\">End of Day Checklist</div>\n      <div class=\"page-sub\">STEP 9 — VERIFY BEFORE CLOSING</div>\n\n      <div class=\"alert alert-warn\">\n        <span class=\"alert-icon\">🎯</span>\n        <span>Filter <strong>Open + Unfulfilled</strong> in Shopify. This list <strong>must be empty</strong> before you finish.</span>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"card-title\">Daily Completion Checklist</div>\n        <div class=\"checklist\" id=\"checklist\">\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">Shopify → Open + Unfulfilled filter is empty</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">All new orders have been processed (shipped or cancelled)</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">Every cancelled order has a note and tag</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">Delivery platform checked and Shopify updated</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">All fulfilled orders from previous days reviewed</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">Delayed orders followed up with courier</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">Returns closed with correct tag and note</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">All delivered orders archived</div>\n</div>\n          <div class=\"check-item\" onclick=\"toggle(this)\">\n<div class=\"check-box\"></div>\n<div class=\"check-label\">No orders left in a pending/incomplete state</div>\n</div>\n        </div>\n        <button class=\"reset-btn\" onclick=\"resetChecklist()\">↺ Reset Checklist</button>\n      </div>\n    </div>\n\n  </main>\n</div>\n\n<footer>\n  <span>Nael Advertising Expert League FZCO · Admin@naeladvertising.ae · +971521785223</span>\n  <span>Dubai, JLT, Cluster C, Palladium Tower</span>\n</footer>\n\n<script>\n  function show(id) {\n    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));\n    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));\n    document.getElementById(id).classList.add('active');\n    event.currentTarget.classList.add('active');\n  }\n\n  function toggle(el) {\n    el.classList.toggle('checked');\n    const box = el.querySelector('.check-box');\n    box.textContent = el.classList.contains('checked') ? '✓' : '';\n  }\n\n  function resetChecklist() {\n    document.querySelectorAll('.check-item').forEach(el => {\n      el.classList.remove('checked');\n      el.querySelector('.check-box').textContent = '';\n    });\n  }\n</script>\n\n</body>",
